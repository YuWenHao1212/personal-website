          <div>
            <label for="companions_info" class="block text-sm font-medium text-[#2C2416] mb-2">同行者姓名 + Email <span id="companions-count-hint" class="text-[#8B7355] font-normal"></span><span class="text-[#DC2626]">*</span></label>
            <textarea id="companions_info" name="companions_info" rows="4" placeholder="例：王小美 wang@example.com&#10;李大華 lee@example.com&#10;陳大衛 david@example.com" class="w-full px-4 py-3 rounded-lg border border-[#E8E4DD] text-base text-[#2C2416] focus:outline-none focus:border-[#B8926A] focus:ring-2 focus:ring-[#B8926A]/20"></textarea>
            <p class="text-xs text-[#8B7355] mt-1">課前我會分別聯繫每位學員</p>
          </div>
        </div>

        <!-- 動態名額（送出鈕上方 echo；額滿時換候補 CTA）。JS 控制顯示 -->
        <div id="availability-inline" class="hidden"></div>

        <button type="submit" id="submit-btn" class="w-full py-4 bg-[#B8926A] text-white text-base md:text-lg font-medium rounded-full hover:bg-[#A67D55] hover:shadow-lg transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed">
          送出報名
        </button>

        <p class="text-xs text-center text-[#8B7355]">
          送出後我會透過 LINE 或 email 主動與你聯繫
        </p>
      </form>

      <!-- Success message (hidden by default) -->
      <div id="success-msg" class="hidden bg-[#D1FAE5] border-2 border-[#059669] rounded-xl p-8 text-center">
        <div class="w-16 h-16 rounded-full bg-[#059669] flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-[#065F46] mb-2">報名與付款已完成！</h3>
        <p class="text-base text-[#065F46] mb-1">我會透過 LINE 或 email 主動與你聯繫。</p>
        <p class="text-sm text-[#047857]">開課前會安排一場課前 1:1；場地於開課前一個月確認後通知。</p>
      </div>

      <!-- Error message (hidden by default) -->
      <div id="error-msg" class="hidden bg-[#FEE2E2] border-2 border-[#DC2626] rounded-xl p-6 text-center">
        <p class="text-base text-[#991B1B]">送出失敗，請直接 email 給我：<a href="mailto:mail@yu-wenhao.com" class="font-medium underline">mail@yu-wenhao.com</a></p>
      </div>

          <p class="text-sm text-center text-[#8B7355] mt-8">
            有問題？直接寫信 <a href="mailto:mail@yu-wenhao.com" class="text-[#B8926A] hover:underline">mail@yu-wenhao.com</a>
          </p>
        </div>
        <!-- /RIGHT -->

      </div>
      <!-- /grid -->
    </div>
  </section>

  <script define:vars={{ API_BASE, SURVEY_ID, PRICING_DEFAULTS, COHORT_DATE_SHORT: cohort.dateShort }}>
    const form = document.getElementById('signup-form');
    const submitBtn = document.getElementById('submit-btn');
    const successMsg = document.getElementById('success-msg');
    const errorMsg = document.getElementById('error-msg');
    const partySizeSelect = document.getElementById('party_size');
    const companionsWrapper = document.getElementById('companions-wrapper');

    // Pricing — 後端 /availability 是唯一 source of truth（依台北時間決定早鳥是否截止）。
    // 預設帶 src/data/cohorts.ts 的早鳥值避免載入前閃爍；loadPricing() 會用後端值覆蓋。
    let pricing = {
      isEarlyBird: PRICING_DEFAULTS.isEarlyBird,
      priceRegular: PRICING_DEFAULTS.priceRegular,
      priceSingle: PRICING_DEFAULTS.priceSingle,
      priceDuo: PRICING_DEFAULTS.priceDuo,
      earlyBirdEnd: PRICING_DEFAULTS.earlyBirdEnd,
    };
    const companionsInfoEl = document.getElementById('companions_info');
    let currentRemaining = null; // 後端 remaining；額滿時擋送出

    function formatTWD(n) {
      return 'NT$' + n.toLocaleString('en-US');
    }

    function updatePricePreview() {
      const value = partySizeSelect.value;
      const breakdownEl = document.getElementById('price-breakdown');
      const totalEl = document.getElementById('price-total');

      const size = parseInt(value, 10);
      const unit = size >= 2 ? pricing.priceDuo : pricing.priceSingle;
      const label = size >= 2 ? '（揪團價）' : (pricing.isEarlyBird ? '（早鳥）' : '');
      breakdownEl.textContent = `${size} 人 × ${formatTWD(unit)}${label}`;
      totalEl.textContent = formatTWD(unit * size);
    }

    // 把當前定價同步到費用卡 / 表單小字 / price-preview
    function applyPricingToUI() {
      const tag = document.getElementById('fee-eb-tag');
      const strike = document.getElementById('fee-regular-strike');
      const single = document.getElementById('fee-single');
      const duo = document.getElementById('fee-duo');
      const note = document.getElementById('fee-note');
      const hint = document.getElementById('form-price-hint');
      const duoSaved = formatTWD(pricing.priceRegular - pricing.priceDuo);

      if (single) single.textContent = formatTWD(pricing.priceSingle);
      if (duo) duo.textContent = formatTWD(pricing.priceDuo);

      if (pricing.isEarlyBird) {
        if (strike) { strike.textContent = formatTWD(pricing.priceRegular); strike.classList.remove('hidden'); }
        if (tag) tag.classList.remove('hidden');
        if (note) note.textContent = `兩人以上每人省 ${duoSaved}，早鳥結束後仍適用。`;
        if (hint) hint.textContent = `早鳥 ${formatTWD(pricing.priceSingle)}（原價 ${formatTWD(pricing.priceRegular)}）· 兩人以上每人 ${formatTWD(pricing.priceDuo)}`;
      } else {
        if (strike) strike.classList.add('hidden');
        if (tag) tag.classList.add('hidden');
        if (note) note.textContent = `兩人以上每人省 ${duoSaved}。`;
        if (hint) hint.textContent = `${formatTWD(pricing.priceRegular)} · 兩人以上每人 ${formatTWD(pricing.priceDuo)}`;
      }
      updatePricePreview();
    }

    // 動態名額顯示 — 真實 remaining 驅動（門檻 ≤5 秀數字），額滿進場即擋（不讓填完表單才撞 409）
    function applyAvailability(remaining) {
      currentRemaining = remaining;
      if (typeof remaining !== 'number') return;
      const badge = document.getElementById('availability-badge');
      const inline = document.getElementById('availability-inline');

      let cls, dot, label;
      if (remaining <= 0) {
        cls = 'bg-[#F3F4F6] text-[#6B7280] border-[#E5E7EB]'; dot = 'bg-[#9CA3AF]'; label = '本梯已額滿';
      } else if (remaining === 1) {
        cls = 'bg-[#FEE2E2] text-[#DC2626] border-[#DC2626]/40'; dot = 'bg-[#DC2626] animate-pulse'; label = '僅剩最後 1 個名額';
      } else if (remaining <= 5) {
        cls = 'bg-[#FEF3C7] text-[#B45309] border-[#D97706]/40'; dot = 'bg-[#D97706]'; label = `僅剩 ${remaining} 個名額`;
      } else {
        cls = 'bg-[#D1FAE5] text-[#047857] border-[#059669]/30'; dot = 'bg-[#059669]'; label = '開放報名中';
      }

      if (badge) {
        badge.innerHTML = `<span class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm font-semibold ${cls}"><span class="w-2 h-2 rounded-full ${dot}"></span>${label}</span>`;
        badge.classList.remove('hidden');
      }

      if (remaining <= 0) {
        submitBtn.disabled = true;
        submitBtn.textContent = '本梯已額滿';
        if (inline) {
          const waitlistSubject = encodeURIComponent(`${COHORT_DATE_SHORT} 工作坊候補`);
          inline.innerHTML = `本梯名額已滿 — <a href="mailto:mail@yu-wenhao.com?subject=${waitlistSubject}" class="font-semibold underline">寫信加入候補 →</a>`;
          inline.className = 'text-sm text-center text-[#991B1B] bg-[#FEE2E2] border border-[#DC2626]/30 rounded-lg p-3';
        }
      } else if (inline) {
        if (remaining <= 5) {
          inline.textContent = remaining === 1 ? '僅剩最後 1 個名額，把握機會' : `僅剩 ${remaining} 個名額`;
          inline.className = 'text-sm text-center font-semibold ' + (remaining === 1 ? 'text-[#DC2626]' : 'text-[#B45309]');
          inline.classList.remove('hidden');
        } else {
          inline.classList.add('hidden');
        }
      }
    }

    async function loadPricing() {
      try {
        const res = await fetch(`${API_BASE}/api/workshop/availability`);
        const json = await res.json();
        const d = json && json.data;
        if (d && typeof d.price_single_twd === 'number') {
          pricing = {
            isEarlyBird: !!d.is_early_bird,
            priceRegular: d.price_regular_twd,
            priceSingle: d.price_single_twd,
            priceDuo: d.price_duo_per_person_twd,
            earlyBirdEnd: d.early_bird_end || pricing.earlyBirdEnd,
          };
        }
        if (d && typeof d.remaining === 'number') {
          applyAvailability(d.remaining);
        }
      } catch (err) {
        console.error('availability fetch failed, using default pricing', err);
      }
      applyPricingToUI();
    }

    // Party size dropdown — show/hide companions textarea + update price + update hint
    partySizeSelect.addEventListener('change', () => {
      const value = partySizeSelect.value;
      const showCompanions = value !== '1';

      if (showCompanions) {
        companionsWrapper.classList.remove('hidden');
        companionsInfoEl.required = true;
        const expectedCount = parseInt(value, 10) - 1;
        const hint = document.getElementById('companions-count-hint');
        if (hint) hint.textContent = `（請填 ${expectedCount} 位）`;
      } else {
        companionsWrapper.classList.add('hidden');
        companionsInfoEl.required = false;
        const hint = document.getElementById('companions-count-hint');
        if (hint) hint.textContent = '';
      }

      updatePricePreview();
    });

    // Initial render（預設早鳥值）→ 立即套 UI，再用後端台北時間覆蓋
    applyPricingToUI();
    loadPricing();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (currentRemaining !== null && currentRemaining <= 0) return; // 已額滿，擋送出

      submitBtn.disabled = true;
      submitBtn.textContent = '建立付款連結...';
      errorMsg.classList.add('hidden');

      const formData = new FormData(form);
      const partySizeRaw = formData.get('party_size');

      // 全部走 Stripe Checkout：1 人早鳥/原價、2 人以上每人 8000（後端算價）
      const partySize = parseInt(partySizeRaw, 10);

      // 驗證同行者筆數必須等於 party_size - 1
      if (partySize > 1) {
        const companionsText = (formData.get('companions_info') || '').trim();
        const companionLines = companionsText.split('\n').filter(l => l.trim() !== '');
        const expectedCount = partySize - 1;
        if (companionLines.length !== expectedCount) {
          errorMsg.textContent = `同行者資料請填 ${expectedCount} 位（目前填了 ${companionLines.length} 位）。每人一行，格式：姓名 email。`;
          errorMsg.classList.remove('hidden');
          errorMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
          submitBtn.disabled = false;
          submitBtn.textContent = '送出報名';
          return;
        }
      }

      try {
        const res = await fetch(`${API_BASE}/api/workshop/create-checkout`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: formData.get('name'),
            email: formData.get('email'),
            line_id: formData.get('line_id'),
            phone: formData.get('phone'),
            role: formData.get('role'),
            party_size: partySize,
            companions_info: formData.get('companions_info') || '',
            dietary: formData.get('dietary') || '',
            message: formData.get('message') || '',
          }),
        });

        if (res.status === 409) {
          const json = await res.json();
          const remaining = json.remaining ?? 0;
          errorMsg.textContent = remaining > 0
            ? `名額不足 — 還剩 ${remaining} 個位置（你想報 ${partySize} 個）。請改成 1 人單獨報名，或直接寫信給 mail@yu-wenhao.com 安排候補。`
            : '名額已滿，請寫信給 mail@yu-wenhao.com 加入候補名單。';
          errorMsg.classList.remove('hidden');
          errorMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
          submitBtn.disabled = false;
          submitBtn.textContent = '送出報名';
          return;
        }

        const json = await res.json();
        if (json.success && json.data?.url) {
          // Redirect to Stripe Checkout
          window.location.href = json.data.url;
        } else {
          throw new Error(json.error || 'Submission failed');
        }
      } catch (err) {
        console.error(err);
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = '重新送出';
      }
    });
  </script>
  <MotionLayer />
</BaseLayout>
