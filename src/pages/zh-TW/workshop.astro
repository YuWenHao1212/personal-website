---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = '一日工作坊：用 AI 建你的個人指揮中心';
const description = '6 小時實作工作坊 — 用 Claude Code + Obsidian 打造目標管理、知識管理、AI 自動化工作流。帶著能跑的系統回家。';
---

<BaseLayout title={title} description={description} hideLanguageSwitcher={true} noindex={true}>
  <!-- Hero -->
  <section class="py-20 md:py-28 lg:py-32 bg-[#F5F1EB]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl">
        <p class="text-sm md:text-base font-medium text-[#B8926A] mb-4 tracking-wide uppercase">Workshop</p>
        <h1 class="text-[2rem] md:text-[2.75rem] lg:text-[3.5rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-6">
          用 AI 建你的個人指揮中心
        </h1>
        <p class="text-xl md:text-2xl leading-relaxed text-[#5C5144] mb-8">
          年度目標年年失敗、筆記存了找不到、每天花一小時「準備開始工作」。<br />問題不是意志力，是看不見自己。
        </p>
        <p class="text-lg md:text-xl leading-relaxed text-[#5C5144] mb-10">
          這堂 6 小時工作坊，帶你從零建一套 AI 驅動的工作系統 — 目標管理、知識管理、每日自動化。<strong class="text-[#2C2416]">帶著能跑的系統回家，不只是聽完一場演講。</strong>
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#signup" class="inline-flex items-center justify-center px-8 py-4 bg-[#B8926A] text-white text-base md:text-lg font-medium rounded-full hover:bg-[#A67D55] hover:shadow-lg hover:scale-105 transition-all duration-200">
            立即報名
          </a>
          <a href="#outline" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#B8926A] text-[#B8926A] text-base md:text-lg font-medium rounded-full hover:bg-[#B8926A] hover:text-white hover:shadow-md hover:scale-105 transition-all duration-200">
            看課程大綱
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="py-20 md:py-28 bg-[#FFFDF9]">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-12">
        這些問題，聽起來熟悉嗎？
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8">
          <div class="text-3xl mb-4">&#x1F3AF;</div>
          <h3 class="text-xl font-semibold text-[#2C2416] mb-3">目標年年設、年年忘</h3>
          <p class="text-base leading-relaxed text-[#5C5144]">一月很興奮，三月就不記得了。OKR、GTD 都試過，問題都一樣 — 得自己記得去追蹤。「記得」本身就是負擔。</p>
        </div>
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8">
          <div class="text-3xl mb-4">&#x1F4DA;</div>
          <h3 class="text-xl font-semibold text-[#2C2416] mb-3">筆記存了找不到</h3>
          <p class="text-base leading-relaxed text-[#5C5144]">三個月前讀的那篇文章、上週開會的重點、去年想到的好點子 — 你知道你記過，但就是找不到。</p>
        </div>
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8">
          <div class="text-3xl mb-4">&#x23F0;</div>
          <h3 class="text-xl font-semibold text-[#5C5144] mb-3">每天一小時「準備開始工作」</h3>
          <p class="text-base leading-relaxed text-[#5C5144]">開信箱、開日曆、開待辦清單、回想昨天做了什麼。資訊散落各處，得自己去收集、判斷輕重緩急。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution -->
  <section class="py-20 md:py-28 bg-[#F5F1EB]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mb-12">
        <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-4">
          上完這堂課，你的早上長這樣
        </h2>
        <p class="text-lg md:text-xl leading-relaxed text-[#5C5144]">
          打開電腦，輸入兩個字：<strong class="text-[#2C2416]">「開工」</strong>。AI 自動跑完 — 回顧昨天進度、查本週目標、掃描信箱、拉行事曆、整理今天的工作清單。3 分鐘後，它問你：「今天先做哪個？」
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-[#B8926A] flex items-center justify-center">
            <span class="text-lg font-bold text-white">1</span>
          </div>
          <div>
            <p class="text-lg font-semibold text-[#2C2416] mb-1">目標管理</p>
            <p class="text-base leading-relaxed text-[#5C5144]">12 Week Year 框架 — 每天知道自己在哪、該往哪走、還差多遠。AI 每週幫你校正方向。</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-[#B8926A] flex items-center justify-center">
            <span class="text-lg font-bold text-white">2</span>
          </div>
          <div>
            <p class="text-lg font-semibold text-[#2C2416] mb-1">知識管理</p>
            <p class="text-base leading-relaxed text-[#5C5144]">Obsidian + LYT 框架 — 筆記不再存了就忘。AI 幫你在需要的時候把三個月前的筆記挖出來。</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-[#B8926A] flex items-center justify-center">
            <span class="text-lg font-bold text-white">3</span>
          </div>
          <div>
            <p class="text-lg font-semibold text-[#2C2416] mb-1">AI 工作流</p>
            <p class="text-base leading-relaxed text-[#5C5144]">Claude Code — 不是聊天機器人，是能讀寫你電腦檔案的 AI 助理。用自然語言指揮，不需要會寫程式。</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-[#B8926A] flex items-center justify-center">
            <span class="text-lg font-bold text-white">4</span>
          </div>
          <div>
            <p class="text-lg font-semibold text-[#2C2416] mb-1">自動化</p>
            <p class="text-base leading-relaxed text-[#5C5144]">從每日規劃、會議準備到內容靈感 — 做一次的事手動做，做三次以上，讓 AI 自動跑。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Course Outline -->
  <section id="outline" class="py-20 md:py-28 bg-[#FFFDF9]">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-4">
        課程大綱
      </h2>
      <p class="text-lg text-[#5C5144] mb-12">6 小時，4 個模組，每個模組都有實作產出。</p>

      <div class="space-y-6">
        <!-- Module 1 -->
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8">
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-[#B8926A]/10 text-[#B8926A] font-bold text-sm">09:30</span>
            <div>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">模組 1：北極星 + 目標管理</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-3">怎麼找到方向、12 Week Year 框架、Lead vs Lag Indicators。現場設定你自己的 12 Week Plan。</p>
              <p class="text-sm text-[#B8926A] font-medium">產出：你的 12 Week Plan（3 條目標線 + 追蹤指標）</p>
            </div>
          </div>
        </div>

        <!-- Module 2 -->
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8">
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-[#B8926A]/10 text-[#B8926A] font-bold text-sm">10:45</span>
            <div>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">模組 2：知識管理 — 你的第二大腦</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-3">Obsidian 安裝 + LYT 框架 + 完整 Vault 架構。不用資料夾分類，用連結把知識串成網。</p>
              <p class="text-sm text-[#B8926A] font-medium">產出：你的 Obsidian Vault（完整架構 + 3 張知識卡片 + 1 個 MOC）</p>
            </div>
          </div>
        </div>

        <!-- Module 3 -->
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8">
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-[#B8926A]/10 text-[#B8926A] font-bold text-sm">13:00</span>
            <div>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">模組 3：AI 工作流 — 讓系統自己跑</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-3">Claude Code 安裝 + CLAUDE.md 個人化設定 + 你的第一個 AI Skill。Live demo：輸入「開工」，看整套系統自動跑完。</p>
              <p class="text-sm text-[#B8926A] font-medium">產出：裝好 Claude Code + 個人化 CLAUDE.md + 跑通第一個 Skill</p>
            </div>
          </div>
        </div>

        <!-- Module 4 -->
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8">
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-[#B8926A]/10 text-[#B8926A] font-bold text-sm">14:30</span>
            <div>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">模組 4：自動化實戰 — 選一個痛點解決</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-3">從三個選項中挑一個，現場跟著做：每日工作規劃自動化 / 會議準備自動化 / 內容靈感收集自動化。</p>
              <p class="text-sm text-[#B8926A] font-medium">產出：多 1 個跑通的自動化 Skill</p>
            </div>
          </div>
        </div>

        <!-- Wrap-up -->
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8">
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 inline-flex items-center justify-center w-10 h-10 rounded-lg bg-[#B8926A]/10 text-[#B8926A] font-bold text-sm">15:30</span>
            <div>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">收尾：串起來 + 下一步</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-3">回顧今天建的系統，看數據怎麼在模組之間流動。畫出你自己的系統架構圖，知道回去後怎麼繼續擴充。</p>
              <p class="text-sm text-[#B8926A] font-medium">產出：你的系統架構圖</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Instructors -->
  <section class="py-20 md:py-28 bg-[#F5F1EB]">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-12">
        講師
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- WenHao -->
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8">
          <h3 class="text-xl font-semibold text-[#2C2416] mb-2">余文皓（Wen-Hao Yu）</h3>
          <p class="text-sm text-[#B8926A] font-medium mb-4">AI 工作流設計 / Full Stack Builder</p>
          <p class="text-base leading-relaxed text-[#5C5144] mb-4">科技業 15 年（工程師 → PM → 數據分析），Minerva University 碩士。目前一個人用 AI 同時推進 5 個產品專案，每天靠這套系統管理所有工作流。</p>
          <div class="space-y-1 text-sm text-[#5C5144]">
            <p>5 個 production 產品在線上運行</p>
            <p>個人網站月流量 60,000+</p>
            <p>Claude Code 教學文章 Google 排名前三</p>
          </div>
        </div>

        <!-- Vista -->
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8">
          <h3 class="text-xl font-semibold text-[#2C2416] mb-2">Vista Cheng</h3>
          <p class="text-sm text-[#B8926A] font-medium mb-4">內容策略 / 個人品牌經營</p>
          <p class="text-base leading-relaxed text-[#5C5144] mb-4">vista.tw 創辦人，電子報 16,000+ 訂閱者。多年內容經營與個人品牌實戰經驗，擅長把知識轉化為有影響力的內容。</p>
          <div class="space-y-1 text-sm text-[#5C5144]">
            <p>電子報 16,000+ 訂閱者</p>
            <p>內容創作與品牌經營多年實戰</p>
            <p>Vibe Coding 社群創辦人</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Who is this for -->
  <section class="py-20 md:py-28 bg-[#FFFDF9]">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-4">
        這堂課適合誰
      </h2>
      <p class="text-lg text-[#5C5144] mb-12">不需要會寫程式。需要的是：想把自己的工作流變好的決心。</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex gap-3">
          <span class="flex-shrink-0 text-[#B8926A] text-xl">&#x2713;</span>
          <p class="text-base md:text-lg text-[#5C5144]">知識工作者 — 每天處理大量資訊，需要系統幫你整理</p>
        </div>
        <div class="flex gap-3">
          <span class="flex-shrink-0 text-[#B8926A] text-xl">&#x2713;</span>
          <p class="text-base md:text-lg text-[#5C5144]">自由工作者 — 一個人扛多個專案，需要系統幫你追蹤</p>
        </div>
        <div class="flex gap-3">
          <span class="flex-shrink-0 text-[#B8926A] text-xl">&#x2713;</span>
          <p class="text-base md:text-lg text-[#5C5144]">內容創作者 — 想穩定產出但常常不知道寫什麼</p>
        </div>
        <div class="flex gap-3">
          <span class="flex-shrink-0 text-[#B8926A] text-xl">&#x2713;</span>
          <p class="text-base md:text-lg text-[#5C5144]">用過 AI 但串不起來 — ChatGPT 會用，但回到工作上還是 copy-paste</p>
        </div>
        <div class="flex gap-3">
          <span class="flex-shrink-0 text-[#B8926A] text-xl">&#x2713;</span>
          <p class="text-base md:text-lg text-[#5C5144]">想認真管理目標 — 試過各種框架，但每次都半途而廢</p>
        </div>
        <div class="flex gap-3">
          <span class="flex-shrink-0 text-[#B8926A] text-xl">&#x2713;</span>
          <p class="text-base md:text-lg text-[#5C5144]">不會寫程式也沒關係 — Claude Code 用自然語言操作</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing + CTA -->
  <section id="signup" class="py-20 md:py-28 lg:py-32 bg-[#F5F1EB]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-[2rem] md:text-[2.5rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-4">
          報名資訊
        </h2>

        <div class="bg-white border border-[#E8E4DD] rounded-xl p-8 md:p-10 mb-8 text-left">
          <div class="space-y-4">
            <div class="flex justify-between items-center border-b border-[#E8E4DD] pb-4">
              <span class="text-base text-[#5C5144]">時長</span>
              <span class="text-base font-medium text-[#2C2416]">6 小時（含休息）</span>
            </div>
            <div class="flex justify-between items-center border-b border-[#E8E4DD] pb-4">
              <span class="text-base text-[#5C5144]">人數</span>
              <span class="text-base font-medium text-[#2C2416]">限 20 人</span>
            </div>
            <div class="flex justify-between items-center border-b border-[#E8E4DD] pb-4">
              <span class="text-base text-[#5C5144]">日期</span>
              <span class="text-base font-medium text-[#2C2416]">即將公佈</span>
            </div>
            <div class="flex justify-between items-center border-b border-[#E8E4DD] pb-4">
              <span class="text-base text-[#5C5144]">地點</span>
              <span class="text-base font-medium text-[#2C2416]">台北（實體）</span>
            </div>
            <div class="flex justify-between items-center border-b border-[#E8E4DD] pb-4">
              <span class="text-base text-[#5C5144]">需要帶</span>
              <span class="text-base font-medium text-[#2C2416]">筆電 + Claude 帳號</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-base text-[#5C5144]">費用</span>
              <div class="text-right">
                <span class="text-sm text-[#8B7355] line-through mr-2">NT$8,000</span>
                <span class="text-2xl font-bold text-[#2C2416]">NT$5,000</span>
                <span class="text-sm text-[#B8926A] ml-1">早鳥價</span>
              </div>
            </div>
          </div>
        </div>

        <p class="text-base text-[#5C5144] mb-8">
          留下 Email，開放報名時第一時間通知你。
        </p>

        <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input type="email" placeholder="your@email.com" class="flex-1 px-5 py-3 rounded-full border border-[#E8E4DD] text-base text-[#2C2416] placeholder-[#8B7355] focus:outline-none focus:border-[#B8926A] focus:ring-2 focus:ring-[#B8926A]/20" />
          <button class="px-8 py-3 bg-[#B8926A] text-white text-base font-medium rounded-full hover:bg-[#A67D55] hover:shadow-lg hover:scale-105 transition-all duration-200">
            通知我
          </button>
        </div>

        <p class="text-sm text-[#8B7355] mt-4">
          有問題？直接寫信 <a href="mailto:mail@yu-wenhao.com" class="text-[#B8926A] hover:underline">mail@yu-wenhao.com</a>
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-28 bg-[#FFFDF9]">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-12">
        常見問題
      </h2>

      <div class="space-y-6">
        <details class="group bg-white border border-[#E8E4DD] rounded-xl">
          <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
            <span class="text-lg font-medium text-[#2C2416]">需要會寫程式嗎？</span>
            <span class="flex-shrink-0 ml-4 text-[#B8926A] group-open:rotate-45 transition-transform duration-200 text-xl">+</span>
          </summary>
          <div class="px-6 pb-6">
            <p class="text-base leading-relaxed text-[#5C5144]">不需要。Claude Code 用自然語言操作 — 你告訴它要做什麼，它幫你做。真正需要的是想清楚自己的工作流：哪些步驟可以自動化、哪些該留給人判斷。</p>
          </div>
        </details>

        <details class="group bg-white border border-[#E8E4DD] rounded-xl">
          <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
            <span class="text-lg font-medium text-[#2C2416]">需要事先準備什麼？</span>
            <span class="flex-shrink-0 ml-4 text-[#B8926A] group-open:rotate-45 transition-transform duration-200 text-xl">+</span>
          </summary>
          <div class="px-6 pb-6">
