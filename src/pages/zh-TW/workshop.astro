---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestimonialWall from '../../components/TestimonialWall.astro';
import MotionLayer from '../../components/MotionLayer.astro';
import { COHORTS, CURRENT_COHORT as cohort, PRICING_DEFAULTS, formatTWD } from '../../data/cohorts';

const title = '用 AI 建你的個人指揮中心｜一日實作工作坊';
const description = `${cohort.dateShort}（${cohort.weekday}）${cohort.city}。6 小時實作，帶走一套能跑的個人 AI 工作系統 — 目標管理、知識管理、AI 自動化工作流。5 月台北、6 月台中、8 月台北三班全滿，10 月第四班招生中。`;

// API base: localhost in dev, production in prod
const API_BASE = import.meta.env.DEV
  ? 'http://localhost:8000'
  : 'https://api.yu-wenhao.com';

const SURVEY_ID = 'workshop-signup-2026-q2';
---

<BaseLayout title={title} description={description} hideLanguageSwitcher={true} noindex={true}>
  <!-- Hero -->
  <section class="py-20 md:py-28 lg:py-32 bg-[#F5F1EB]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl">
        <p class="rv text-sm md:text-base font-medium text-[#B8926A] mb-4 tracking-wide">{cohort.dateShort}（{cohort.weekday}）{cohort.city} · {cohort.name}招生中</p>
        <h1 class="sv-hero-title text-[1.75rem] sm:text-[2rem] md:text-[2.5rem] font-bold text-[#2C2416] leading-[1.15] tracking-[-0.02em] mb-5 whitespace-nowrap">
          <span class="ln"><span class="ln-i">用 AI 建你的個人指揮中心</span></span>
        </h1>
        <p class="rv text-lg md:text-xl leading-relaxed text-[#B8926A] font-medium mb-6">
          多數人學 AI 的順序反了。我的順序 — 先方向、再系統，AI 才是槓桿。
        </p>
        <p class="rv text-xl md:text-2xl leading-relaxed text-[#5C5144] mb-4">
          一日實作工作坊 — 一套系統，管目標、管知識、管客戶、管產出。
        </p>
        <p class="rv text-base md:text-lg leading-relaxed text-[#8B7355] mb-10">
          不用會寫程式，用說的就好。
        </p>
        <div class="rv flex flex-wrap gap-4 mb-8">
          <a href="#signup" class="inline-flex items-center justify-center px-8 py-4 bg-[#B8926A] text-white text-base md:text-lg font-medium rounded-full hover:bg-[#A67D55] hover:shadow-lg hover:scale-105 transition-all duration-200">
            填寫報名表
          </a>
          <a href="#outline" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#B8926A] text-[#B8926A] text-base md:text-lg font-medium rounded-full hover:bg-[#B8926A] hover:text-white hover:shadow-md hover:scale-105 transition-all duration-200">
            看課程大綱
          </a>
        </div>
        <!-- Quick info badges -->
        <div class="rv flex flex-wrap gap-3 text-sm text-[#5C5144]">
          <span class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            {cohort.dateFull}
          </span>
          <span class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            6 小時實作
          </span>
          <span class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            {cohort.capacity} 人小班
          </span>
          <span class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            {cohort.city} · 實體授課
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Story arc: the reader's stuck moment → honest promise -->
  <section class="py-20 md:py-28 bg-[#FFFDF9]">
    <div class="max-w-3xl mx-auto px-6">
      <p class="rv text-xl md:text-2xl leading-relaxed text-[#2C2416] font-medium mb-8">
        Claude Code 裝好了。終端機打開，游標在閃 — 然後呢？
      </p>
      <p class="rv text-lg md:text-xl leading-relaxed text-[#5C5144] mb-8">
        你問了幾個問題，它答得不錯。但你的專案、你的目標、每天真正的工作，不知道怎麼交給它。它不認識你 — 不知道你在做什麼案子、這週在趕什麼、檔案放在哪。每次都得從頭解釋，解釋到累了，就回去用原來的方法。
      </p>
      <p class="rv text-lg md:text-xl leading-relaxed text-[#5C5144] mb-8">
        說實話：讓 AI 真的進到工作裡，最花力氣的就是一開始的建置 — 也是最多人放棄的地方。這堂課做的，就是把這段最難的路，變成有人帶著走完的 6 小時。
      </p>
      <p class="rv text-lg md:text-xl leading-relaxed text-[#B8926A] font-medium">
        怎麼走？先把順序弄對。
      </p>
    </div>
  </section>

  <!-- Solution — FLUX 三層 × 以前 vs 現在 -->
  <section class="py-20 md:py-28 bg-[#2C2416]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mb-14">
        <p class="text-sm md:text-base font-medium text-[#B8926A] mb-3 tracking-wide">我的順序：FLUX 三層</p>
        <h2 class="rv text-[1.75rem] md:text-[2.25rem] font-bold text-white leading-[1.1] tracking-[-0.02em] mb-4">
          上完這堂課，你的工作長這樣
        </h2>
        <p class="text-lg md:text-xl leading-relaxed text-[#C4B9A8]">
          FLUX 是這個順序的具體答案 — <strong class="text-white">方向層、系統層、槓桿層</strong>，每天陪你跑完一個完整 loop。
        </p>
      </div>

      <div class="space-y-6 md:space-y-8">
        <!-- 方向層 -->
        <div class="bg-[#3D3426] border border-[#5C5144] rounded-xl p-6 md:p-8 grid grid-cols-1 md:grid-cols-[200px_1fr] gap-6">
          <div>
            <p class="text-xs md:text-sm font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-2">方向層 · Focus</p>
            <p class="text-2xl md:text-3xl font-bold text-white leading-tight">今天該推哪一步？</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <p class="text-xs font-medium text-[#8B7355] mb-1 tracking-wide uppercase">以前</p>
              <p class="text-base leading-relaxed text-[#C4B9A8]">年初寫滿一頁年度目標、3 月忘光。每天打開電腦不知道該做什麼。</p>
            </div>
            <div>
              <p class="text-xs font-medium text-[#B8926A] mb-1 tracking-wide uppercase">現在</p>
              <p class="text-base leading-relaxed text-white">以 12 週為單位，每天早上問一句「今天做什麼」— 3 分鐘，AI 告訴你該推哪一步、這週的優先順序在哪。</p>
            </div>
          </div>
        </div>

        <!-- 系統層 -->
        <div class="bg-[#3D3426] border border-[#5C5144] rounded-xl p-6 md:p-8 grid grid-cols-1 md:grid-cols-[200px_1fr] gap-6">
          <div>
            <p class="text-xs md:text-sm font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-2">系統層 · Learn + Upgrade</p>
            <p class="text-2xl md:text-3xl font-bold text-white leading-tight">3 個月前學的、找得到嗎？</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <p class="text-xs font-medium text-[#8B7355] mb-1 tracking-wide uppercase">以前</p>
              <p class="text-base leading-relaxed text-[#C4B9A8]">學到的東西散在 Notion / Apple Notes / 收藏夾、3 個月後找不到。每次都從零再學一次。</p>
            </div>
            <div>
              <p class="text-xs font-medium text-[#B8926A] mb-1 tracking-wide uppercase">現在</p>
              <p class="text-base leading-relaxed text-white">學到的東西丟給 AI、說一聲「收起來」— 自動分類歸檔、跟舊筆記連起來。要找的時候，5 秒。</p>
            </div>
          </div>
        </div>

        <!-- 槓桿層 -->
        <div class="bg-[#3D3426] border border-[#5C5144] rounded-xl p-6 md:p-8 grid grid-cols-1 md:grid-cols-[200px_1fr] gap-6">
          <div>
            <p class="text-xs md:text-sm font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-2">槓桿層 · eXecute</p>
            <p class="text-2xl md:text-3xl font-bold text-white leading-tight">AI 真的幫到你嗎？</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <p class="text-xs font-medium text-[#8B7355] mb-1 tracking-wide uppercase">以前</p>
              <p class="text-base leading-relaxed text-[#C4B9A8]">每次叫 ChatGPT 做事都要重新解釋一次 context。AI 像個失憶的實習生。</p>
            </div>
            <div>
              <p class="text-xs font-medium text-[#B8926A] mb-1 tracking-wide uppercase">現在</p>
              <p class="text-base leading-relaxed text-white">AI 認得你 — 知道你的工作習慣、找得到你的筆記、看得到你的信箱和行事曆。常用流程教它一次、存成 Skill，以後說一句「開工」，它自己跑完一整套。</p>
            </div>
          </div>
        </div>
      </div>

      <p class="text-lg md:text-xl leading-relaxed text-white font-medium mt-12 max-w-3xl">
        三層都在 — AI 才會變成你的槓桿，不是你的玩具。
      </p>
    </div>
  </section>

  <!-- Course Outline — merged with「帶走什麼」(2026-07-18 三合二，入門者語言) -->
  <section id="outline" class="py-20 md:py-28 bg-[#F5F1EB]">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="rv text-[1.75rem] md:text-[2.25rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-4">
        課程大綱 — 這 6 小時會發生什麼
      </h2>
      <p class="rv text-lg text-[#5C5144] mb-12">全程動手做。每個時段結束，你電腦裡就多一樣真的在跑的東西。</p>

      <!-- Timeline -->
      <div class="relative">
        <div class="absolute left-6 md:left-8 top-0 bottom-0 w-0.5 bg-[#E8E4DD]"></div>

        <div class="space-y-8">
          <!-- Block 1 -->
          <div class="rv relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#E0E7FF] flex flex-col items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-bold text-[#4F46E5] leading-none">09:00</span>
            </div>
            <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8 flex-1 shadow-sm">
              <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-1.5">Block 1 · 打地基</p>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">AI 助理 — 認識你的新夥伴</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-4">第一件事：把 Claude Code 裝進你的電腦，然後教它認識你 — 你的工作、你的習慣、你說話的方式。裝好之後，接下來一整天你都用它做事。</p>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-[#B8926A] font-medium">帶走：一個認得你的 AI 助理，住在你電腦裡</span>
              </div>
            </div>
          </div>

          <!-- Block 2 -->
          <div class="rv relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#FEF3C7] flex flex-col items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-bold text-[#D97706] leading-none">10:30</span>
            </div>
            <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8 flex-1 shadow-sm">
              <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-1.5">Block 2 · 方向</p>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">目標管理 — 從十二週目標到今天</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-4">把「今年想做的事」變成十二週的計畫，再拆到每一天。上完課之後，每天早上問一句「今天做什麼」，AI 看過你的目標和進度，直接告訴你該推哪一步。</p>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-[#B8926A] font-medium">帶走：你自己的目標追蹤系統 — 每天打開就知道該做什麼</span>
              </div>
            </div>
          </div>

          <!-- Lunch -->
          <div class="relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#F5F1EB] flex items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-medium text-[#8B7355] leading-none">12:30</span>
            </div>
            <div class="flex items-center">
              <p class="text-sm text-[#8B7355] italic">午餐 1 小時</p>
            </div>
          </div>

          <!-- Block 3 -->
          <div class="rv relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#DBEAFE] flex flex-col items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-bold text-[#2563EB] leading-none">13:30</span>
            </div>
            <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8 flex-1 shadow-sm">
              <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-1.5">Block 3 · 系統</p>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">知識管理 — 找得到東西的筆記庫</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-4">讀過的文章、開過的會、學過的東西，丟給 AI、說一聲「收起來」— 它自動分類歸檔、跟舊的筆記連起來。現場整理你自己的第一批筆記，之後要找什麼，5 秒。</p>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-[#B8926A] font-medium">帶走：一個找得到東西的知識庫，已經開始運轉</span>
              </div>
            </div>
          </div>

          <!-- Block 4 -->
          <div class="rv relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#D1FAE5] flex flex-col items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-bold text-[#059669] leading-none">14:45</span>
            </div>
            <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8 flex-1 shadow-sm">
              <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-1.5">Block 4 · 槓桿</p>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">把流程教給 AI — 從零建你的第一個 Skill</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-4">先弄懂 Skill 的原理 — 為什麼教一次，以後一句話它就能自己跑完一整套。然後帶你從零建出自己的第一個。最後把信箱和行事曆接給 AI，從此它排今天的計畫時，看得到你的會議和信件。</p>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-[#B8926A] font-medium">帶走：你親手建的第一個 Skill，加上接好信箱、行事曆的 AI</span>
              </div>
            </div>
          </div>

          <!-- Finale -->
          <div class="rv relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#2C2416] flex flex-col items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-bold text-white leading-none">15:30</span>
            </div>
            <div class="bg-white border-2 border-[#2C2416] rounded-xl p-6 md:p-8 flex-1 shadow-sm">
              <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-1.5">Finale · 串起來</p>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">收尾 — 現場跑一次完整流程</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-4">把今天建的東西串在一起，每個人現場跑一遍：問「今天做什麼」→ AI 排好 → 做完的東西收進知識庫。確認你的系統會動了，才回家。</p>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-[#B8926A] font-medium">帶走：一套隔天早上就能用的個人指揮中心</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="rv mt-12 bg-[#FFFDF9] border border-[#E8E4DD] rounded-2xl p-6 md:p-8">
        <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-3">課堂裡你會學會的一件事</p>
        <p class="text-lg md:text-xl font-semibold text-[#2C2416] mb-3">把你的流程教給 AI — 這就是 Skill。</p>
        <p class="text-base md:text-lg leading-relaxed text-[#5C5144] mb-3">教一次，以後一句話就能重跑一整套：說「開工」，AI 看過你的目標和行事曆，排好今天該做的事；說「收進筆記庫」，它自動歸檔、連上舊筆記。課堂上你會親手建出自己的第一個 Skill — 回家照同一個方法，繼續建下一個。</p>
        <p class="text-base md:text-lg font-semibold text-[#2C2416]">不是投影片，不是筆記 — 是你電腦裡真的在跑的東西。</p>
      </div>
    </div>
  </section>

  <!-- 梯次紀錄 + 課堂實況 -->
  <section class="py-20 md:py-28 bg-[#FFFDF9]">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="rv text-[1.75rem] md:text-[2.25rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-4">
        開了三班，班班全滿
      </h2>
      <p class="rv text-lg md:text-xl text-[#5C5144] mb-12 max-w-2xl leading-relaxed">
