        <h3 class="text-xl font-bold text-[#065F46] mb-2">報名表已收到！</h3>
        <p class="text-base text-[#065F46] mb-1">我會在 1-2 天內透過 LINE 或 email 跟你聯繫。</p>
        <p class="text-sm text-[#047857]">滿 5 人即正式成班，會通知你最終日期與付款方式。</p>
      </div>

      <!-- Error message (hidden by default) -->
      <div id="error-msg" class="hidden bg-[#FEE2E2] border-2 border-[#DC2626] rounded-xl p-6 text-center">
        <p class="text-base text-[#991B1B]">送出失敗，請直接 email 給我：<a href="mailto:mail@yu-wenhao.com" class="font-medium underline">mail@yu-wenhao.com</a></p>
      </div>

          <p class="text-sm text-center text-[#8B7355] mt-8">
            有問題？直接寫信 <a href="mailto:mail@yu-wenhao.com" class="text-[#B8926A] hover:underline">mail@yu-wenhao.com</a>
          </p>
        </div>
        <!-- /RIGHT -->

      </div>
      <!-- /grid -->
    </div>
  </section>

  <script define:vars={{ API_BASE, SURVEY_ID }}>
    const form = document.getElementById('signup-form');
    const submitBtn = document.getElementById('submit-btn');
    const successMsg = document.getElementById('success-msg');
    const errorMsg = document.getElementById('error-msg');
    const partySizeSelect = document.getElementById('party_size');
    const companionsWrapper = document.getElementById('companions-wrapper');
    const companionBlocks = document.querySelectorAll('.companion-block');

    // Party size dropdown — show/hide companion blocks
    partySizeSelect.addEventListener('change', () => {
      const value = partySizeSelect.value;
      // "6+" → no inline companion fields (user writes count in message)
      const companionCount = value === '6+' ? 0 : parseInt(value, 10) - 1;

      if (companionCount === 0) {
        companionsWrapper.classList.add('hidden');
      } else {
        companionsWrapper.classList.remove('hidden');
      }

      companionBlocks.forEach((block) => {
        const idx = parseInt(block.dataset.index, 10);
        const isVisible = idx <= companionCount;
        if (isVisible) {
          block.classList.remove('hidden');
          block.querySelector('input[type="text"]').required = true;
          block.querySelector('input[type="email"]').required = true;
        } else {
          block.classList.add('hidden');
          block.querySelector('input[type="text"]').required = false;
          block.querySelector('input[type="email"]').required = false;
        }
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = '送出中...';
      errorMsg.classList.add('hidden');

      const formData = new FormData(form);
      const partySizeRaw = formData.get('party_size');
      const isLargeGroup = partySizeRaw === '6+';
      const partySize = isLargeGroup ? '6+' : parseInt(partySizeRaw, 10);
      const companionCount = isLargeGroup ? 0 : partySize - 1;

      // Build companion list
      const companions = [];
      for (let i = 1; i <= companionCount; i++) {
        companions.push({
          name: formData.get(`c${i}_name`) || '',
          email: formData.get(`c${i}_email`) || '',
          pain: formData.get(`c${i}_pain`) || '',
        });
      }

      // Pack all fields except email/role into scenario JSON
      const scenarioData = {
        name: formData.get('name'),
        line_id: formData.get('line_id'),
        pain: formData.get('pain'),
        current_tools: formData.get('current_tools') || '',
        dietary: formData.get('dietary') || '',
        message: formData.get('message') || '',
        party_size: partySize,
        companions: companions,
        submitted_at: new Date().toISOString(),
      };

      try {
        const res = await fetch(`${API_BASE}/api/survey/submit`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            survey_id: SURVEY_ID,
            email: formData.get('email'),
            role: formData.get('role'),
            scenario: JSON.stringify(scenarioData),
          }),
        });

        const json = await res.json();
        if (json.success) {
          form.classList.add('hidden');
          successMsg.classList.remove('hidden');
          successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error(json.error || 'Submission failed');
        }
      } catch (err) {
        console.error(err);
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = '重新送出';
      }
    });
  </script>
</BaseLayout>
