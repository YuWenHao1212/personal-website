---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = '用 AI 建你的個人指揮中心｜一日實作工作坊';
const description = '8/22（六）台北。6 小時實作，帶走一套能跑的個人 AI 工作系統 — 目標管理、知識管理、AI 自動化工作流。5 月首班 12 人滿班，8 月第二班招生中。';

// API base: localhost in dev, production in prod
const API_BASE = import.meta.env.DEV
  ? 'http://localhost:8000'
  : 'https://yu-wenhao-api.calmisland-ea7fe91e.japaneast.azurecontainerapps.io';

const SURVEY_ID = 'workshop-signup-2026-q2';
---

<BaseLayout title={title} description={description} hideLanguageSwitcher={true} noindex={true}>
  <!-- Hero -->
  <section class="py-20 md:py-28 lg:py-32 bg-[#F5F1EB]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl">
        <p class="text-sm md:text-base font-medium text-[#B8926A] mb-4 tracking-wide">8/22（六）台北 · 招生中</p>
        <h1 class="text-[1.75rem] sm:text-[2rem] md:text-[2.5rem] font-bold text-[#2C2416] leading-[1.15] tracking-[-0.02em] mb-5 whitespace-nowrap">
          用 AI 建你的個人指揮中心
        </h1>
        <p class="text-lg md:text-xl leading-relaxed text-[#B8926A] font-medium mb-6">
          多數人學 AI 的順序反了。我的順序 — 先方向、再系統，AI 才是槓桿。
        </p>
        <p class="text-xl md:text-2xl leading-relaxed text-[#5C5144] mb-4">
          一日實作工作坊 — 一套系統，管目標、管知識、管客戶、管產出。
        </p>
        <p class="text-base md:text-lg leading-relaxed text-[#8B7355] mb-10">
          不用會寫程式，用說的就好。
        </p>
        <div class="flex flex-wrap gap-4 mb-8">
          <a href="#signup" class="inline-flex items-center justify-center px-8 py-4 bg-[#B8926A] text-white text-base md:text-lg font-medium rounded-full hover:bg-[#A67D55] hover:shadow-lg hover:scale-105 transition-all duration-200">
            填寫報名表
          </a>
          <a href="#outline" class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#B8926A] text-[#B8926A] text-base md:text-lg font-medium rounded-full hover:bg-[#B8926A] hover:text-white hover:shadow-md hover:scale-105 transition-all duration-200">
            看課程大綱
          </a>
        </div>
        <!-- Quick info badges -->
        <div class="flex flex-wrap gap-3 text-sm text-[#5C5144]">
          <span class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            2026/8/22（六）
          </span>
          <span class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            6 小時實作
          </span>
          <span class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            12 人小班
          </span>
          <span class="inline-flex items-center gap-1.5 bg-white/60 backdrop-blur px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            台北 · 實體授課
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution — FLUX 三層 × 以前 vs 現在 -->
  <section class="py-20 md:py-28 bg-[#2C2416]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mb-14">
        <p class="text-sm md:text-base font-medium text-[#B8926A] mb-3 tracking-wide">我的順序：FLUX 三層</p>
        <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold text-white leading-[1.1] tracking-[-0.02em] mb-4">
          上完這堂課，你的工作長這樣
        </h2>
        <p class="text-lg md:text-xl leading-relaxed text-[#C4B9A8]">
          FLUX 是這個順序的具體答案 — <strong class="text-white">方向層、系統層、槓桿層</strong>，每天陪你跑完一個完整 loop。
        </p>
      </div>

      <div class="space-y-6 md:space-y-8">
        <!-- 方向層 -->
        <div class="bg-[#3D3426] border border-[#5C5144] rounded-xl p-6 md:p-8 grid grid-cols-1 md:grid-cols-[200px_1fr] gap-6">
          <div>
            <p class="text-xs md:text-sm font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-2">方向層 · Focus</p>
            <p class="text-2xl md:text-3xl font-bold text-white leading-tight">今天該推哪一步？</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <p class="text-xs font-medium text-[#8B7355] mb-1 tracking-wide uppercase">以前</p>
              <p class="text-base leading-relaxed text-[#C4B9A8]">年初寫滿一頁年度目標、3 月忘光。每天打開電腦不知道該做什麼。</p>
            </div>
            <div>
              <p class="text-xs font-medium text-[#B8926A] mb-1 tracking-wide uppercase">現在</p>
              <p class="text-base leading-relaxed text-white">12 週為單位、每天打「<span class="font-mono text-[#D4B696]">/daily</span>」3 分鐘就知道今天該推哪一步、本週優先順序在哪裡。</p>
            </div>
          </div>
        </div>

        <!-- 系統層 -->
        <div class="bg-[#3D3426] border border-[#5C5144] rounded-xl p-6 md:p-8 grid grid-cols-1 md:grid-cols-[200px_1fr] gap-6">
          <div>
            <p class="text-xs md:text-sm font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-2">系統層 · Learn + Upgrade</p>
            <p class="text-2xl md:text-3xl font-bold text-white leading-tight">3 個月前學的、找得到嗎？</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <p class="text-xs font-medium text-[#8B7355] mb-1 tracking-wide uppercase">以前</p>
              <p class="text-base leading-relaxed text-[#C4B9A8]">學到的東西散在 Notion / Apple Notes / 收藏夾、3 個月後找不到。每次都從零再學一次。</p>
            </div>
            <div>
              <p class="text-xs font-medium text-[#B8926A] mb-1 tracking-wide uppercase">現在</p>
              <p class="text-base leading-relaxed text-white">Atlas 收一張卡 = 一個概念、跟舊筆記自動連起來。打「<span class="font-mono text-[#D4B696]">[歸檔]</span>」、Claude 自動分類入庫。要找 — 5 秒。</p>
            </div>
          </div>
        </div>

        <!-- 槓桿層 -->
        <div class="bg-[#3D3426] border border-[#5C5144] rounded-xl p-6 md:p-8 grid grid-cols-1 md:grid-cols-[200px_1fr] gap-6">
          <div>
            <p class="text-xs md:text-sm font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-2">槓桿層 · eXecute</p>
            <p class="text-2xl md:text-3xl font-bold text-white leading-tight">AI 真的幫到你嗎？</p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <p class="text-xs font-medium text-[#8B7355] mb-1 tracking-wide uppercase">以前</p>
              <p class="text-base leading-relaxed text-[#C4B9A8]">每次叫 ChatGPT 做事都要重新解釋一次 context。AI 像個失憶的實習生。</p>
            </div>
            <div>
              <p class="text-xs font-medium text-[#B8926A] mb-1 tracking-wide uppercase">現在</p>
              <p class="text-base leading-relaxed text-white">Claude Code 讀你的 <span class="font-mono text-[#D4B696]">CLAUDE.md</span> + Skills，第一句話就上手 — 知道你的工作習慣、找得到你的筆記、串得起你的 Gmail 和行事曆。</p>
            </div>
          </div>
        </div>
      </div>

      <p class="text-lg md:text-xl leading-relaxed text-white font-medium mt-12 max-w-3xl">
        三層都在 — AI 才會變成你的槓桿，不是你的玩具。
      </p>
    </div>
  </section>

  <!-- What you'll take home — 5/16 真實產出 -->
  <section class="py-20 md:py-28 bg-[#FFFDF9]">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-4">
        上完課你帶走什麼
      </h2>
      <p class="text-lg text-[#5C5144] mb-12">不是投影片，不是筆記。是你電腦裡真的在跑的東西。</p>

      <!-- 4 個系統 -->
      <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-4">4 個系統</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-12">
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-5 md:p-6">
          <p class="text-2xl font-bold text-[#B8926A] mb-3">01</p>
          <p class="text-lg font-semibold text-[#2C2416] mb-1">AI 助理</p>
          <p class="text-sm leading-relaxed text-[#2C2416] mb-2">你電腦裡的 AI 夥伴</p>
          <p class="text-xs text-[#8B7355] font-mono">Claude Code + FLUX vault</p>
        </div>
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-5 md:p-6">
          <p class="text-2xl font-bold text-[#B8926A] mb-3">02</p>
          <p class="text-lg font-semibold text-[#2C2416] mb-1">目標系統</p>
          <p class="text-sm leading-relaxed text-[#2C2416] mb-2">12 週目標追蹤、每天知道該做什麼</p>
          <p class="text-xs text-[#8B7355] font-mono">PLAN.md + 週計分卡</p>
        </div>
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-5 md:p-6">
          <p class="text-2xl font-bold text-[#B8926A] mb-3">03</p>
          <p class="text-lg font-semibold text-[#2C2416] mb-1">知識系統</p>
          <p class="text-sm leading-relaxed text-[#2C2416] mb-2">找得到東西的筆記庫</p>
          <p class="text-xs text-[#8B7355] font-mono">Atlas 卡片庫 + 第一張卡</p>
        </div>
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-5 md:p-6">
          <p class="text-2xl font-bold text-[#B8926A] mb-3">04</p>
          <p class="text-lg font-semibold text-[#2C2416] mb-1">自動化</p>
          <p class="text-sm leading-relaxed text-[#2C2416] mb-2">Claude 連上你的 Gmail / Calendar</p>
          <p class="text-xs text-[#8B7355] font-mono">Connector + 第一個 Skill</p>
        </div>
      </div>

      <!-- 3 個 Skill -->
      <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-4">3 個 Skill — 課堂上親手抽出來的</p>
      <p class="text-sm text-[#5C5144] mb-5">Skill = 一個你訓練給 AI 的「指令」。打一次 — AI 跑一整套流程。</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-5 md:p-6">
          <div class="flex items-baseline gap-2 mb-2">
            <span class="text-lg font-bold text-[#059669]">✓</span>
            <p class="text-lg font-semibold text-[#2C2416]">自動把筆記分類入庫</p>
          </div>
          <p class="text-xs font-mono text-[#8B7355]">/knowledge-keeper</p>
        </div>
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-5 md:p-6">
          <div class="flex items-baseline gap-2 mb-2">
            <span class="text-lg font-bold text-[#059669]">✓</span>
            <p class="text-lg font-semibold text-[#2C2416]">每天 3 分鐘知道今天該做什麼</p>
          </div>
          <p class="text-xs font-mono text-[#8B7355]">/daily</p>
        </div>
        <div class="bg-[#FEF3C7]/40 border-2 border-dashed border-[#D97706] rounded-xl p-5 md:p-6">
          <div class="flex items-baseline gap-2 mb-2">
            <span class="text-lg font-bold text-[#D97706]">⏳</span>
            <p class="text-lg font-semibold text-[#2C2416]">每週對齊目標、算分、lock 下週</p>
          </div>
          <p class="text-xs font-mono text-[#8B7355]">/wam</p>
        </div>
      </div>

      <div class="mt-12 bg-[#F5F1EB] border border-[#E8E4DD] rounded-2xl p-6 md:p-8 text-center">
        <p class="text-lg md:text-xl font-semibold text-[#2C2416]">
          全部串在一起 = 一套隔天就能用的個人指揮中心
        </p>
      </div>
    </div>
  </section>

  <!-- Course Outline -->
  <section id="outline" class="py-20 md:py-28 bg-[#F5F1EB]">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-[1.75rem] md:text-[2.25rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-4">
        課程大綱
      </h2>
      <p class="text-lg text-[#5C5144] mb-12">6 小時實作，從個人工作系統到會議全流程，每個主題都有你親手做的成果帶回家。</p>

      <!-- Timeline -->
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-6 md:left-8 top-0 bottom-0 w-0.5 bg-[#E8E4DD]"></div>

        <div class="space-y-8">
          <!-- Block 1: AI 助理 (槓桿層底座) -->
          <div class="relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#E0E7FF] flex flex-col items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-bold text-[#4F46E5] leading-none">09:00</span>
            </div>
            <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8 flex-1 shadow-sm">
              <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-1.5">Block 1 · 槓桿層底座</p>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">AI 助理 — 認識你的新夥伴</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-4">第一件事：在你的電腦裝好 Claude Code。教它認識你的工作環境（VS Code、Markdown、Obsidian、Terminal），寫好 CLAUDE.md 翻譯你的話給 AI 聽。裝好之後，後面每個 Block 都直接用 AI 來做。</p>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-[#B8926A] font-medium">產出：Claude Code + FLUX vault（個人 AI 助理）</span>
              </div>
            </div>
          </div>

          <!-- Block 2: 目標管理 (方向層) -->
          <div class="relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#FEF3C7] flex flex-col items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-bold text-[#D97706] leading-none">10:30</span>
            </div>
            <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8 flex-1 shadow-sm">
              <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-1.5">Block 2 · 方向層</p>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">目標管理 — 從 12 週目標到每天</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-4">用 12 週做時間單位，把目標切成 Effort + Lead/Lag 指標。WAM 每週對齊，<span class="font-mono">/daily</span> 每天 3 分鐘知道今天該推哪一步。不是年度計畫那種寫完就忘的東西。</p>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-[#B8926A] font-medium">產出：PLAN.md + WEEKLY-SCORECARD（你的目標系統）</span>
              </div>
            </div>
          </div>

          <!-- Lunch -->
          <div class="relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#F5F1EB] flex items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-medium text-[#8B7355] leading-none">12:30</span>
            </div>
            <div class="flex items-center">
              <p class="text-sm text-[#8B7355] italic">午餐 1 小時</p>
            </div>
          </div>

          <!-- Block 3: 知識管理 (系統層) -->
          <div class="relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#DBEAFE] flex flex-col items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-bold text-[#2563EB] leading-none">13:30</span>
            </div>
            <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8 flex-1 shadow-sm">
              <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-1.5">Block 3 · 系統層</p>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">知識管理 — 找得到東西的筆記庫</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-4">用 Atlas 把筆記分成 5 類卡片，一張卡 = 一個概念。打 <span class="font-mono">[歸檔]</span>、Claude 自動分類入庫、跟舊筆記連起來。動手建你的第 1、2 張卡，順便完成第一個 Skill：<span class="font-mono">/knowledge-keeper</span>。</p>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-4 h-4 text-[#B8926A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-[#B8926A] font-medium">產出：Atlas + 第一張卡 + <span class="font-mono">/knowledge-keeper</span> Skill</span>
              </div>
            </div>
          </div>

          <!-- Block 4: 自動化 (槓桿層放大) -->
          <div class="relative flex gap-6 md:gap-8">
            <div class="flex-shrink-0 w-12 md:w-16 h-12 md:h-16 rounded-2xl bg-[#D1FAE5] flex flex-col items-center justify-center z-10 border-2 border-white shadow-sm">
              <span class="text-xs font-bold text-[#059669] leading-none">14:45</span>
            </div>
            <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8 flex-1 shadow-sm">
              <p class="text-xs font-bold text-[#B8926A] tracking-[0.2em] uppercase mb-1.5">Block 4 · 槓桿層放大</p>
              <h3 class="text-xl font-semibold text-[#2C2416] mb-2">自動化 — 連上你的世界</h3>
              <p class="text-base leading-relaxed text-[#5C5144] mb-4">用 Connector 把 Gmail 和 Calendar 接進來，Claude 真的看得到你的世界。然後把今天用熟的 <span class="font-mono">/daily</span> 從 CLAUDE.md 抽出來、變成你的第一個正式 Skill。回家用同一份範本，繼續抽自己的下一個。</p>
              <div class="flex items-center gap-2 text-sm">
