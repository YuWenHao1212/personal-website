---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = 'AI 會議筆記 + 即時戰術顧問 — 產品化調查';
const description = '會前自動生成 playbook，會中即時給建議，會後自動產出會議記錄。目前是個人 prototype，正在評估產品化方向。';
---

<BaseLayout title={title} description={description} hideLanguageSwitcher={true}>
  <section class="min-h-[calc(100vh-80px)] flex items-center py-16 md:py-20 bg-[#F5F1EB]">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">

        <!-- Left: Content -->
        <div>
          <p class="text-sm font-medium text-[#B8926A] mb-3 tracking-wide uppercase">Product Survey</p>
          <h1 class="text-[1.75rem] md:text-[2.25rem] lg:text-[2.75rem] font-bold text-[#2C2416] leading-[1.15] tracking-[-0.02em] mb-6">
            AI 會議筆記<br />+ 即時戰術顧問
          </h1>

          <ul class="space-y-4 mb-8">
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-[#B8926A]/10 flex items-center justify-center text-sm font-bold text-[#B8926A]">1</span>
              <div>
                <span class="font-semibold text-[#2C2416]">會前</span>
                <span class="text-[#5C5144]"> — AI 自動生成會議作戰手冊</span>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-[#B8926A]/10 flex items-center justify-center text-sm font-bold text-[#B8926A]">2</span>
              <div>
                <span class="font-semibold text-[#2C2416]">會中</span>
                <span class="text-[#5C5144]"> — One click，AI 根據現場對話給即時建議</span>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-[#B8926A]/10 flex items-center justify-center text-sm font-bold text-[#B8926A]">3</span>
              <div>
                <span class="font-semibold text-[#2C2416]">會後</span>
                <span class="text-[#5C5144]"> — 逐字稿 + playbook 自動產出會議記錄</span>
              </div>
            </li>
          </ul>

          <p class="text-sm text-[#8B7355]">
            目前是個人 prototype，正在評估產品化方向。
            <a href="/zh-TW/blog/ai-meeting-notes" class="text-[#B8926A] hover:underline">看完整開發故事 &rarr;</a>
          </p>
        </div>

        <!-- Right: Form -->
        <div class="bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8 shadow-sm">
          <h2 class="text-xl md:text-2xl font-bold text-[#2C2416] mb-2">產品化調查</h2>
          <p class="text-[#5C5144] mb-6">覺得這個工具該存在？留下 email，有進展第一時間通知你。</p>

          <form id="survey-form" class="space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-[#2C2416] mb-1">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="your@email.com"
                class="w-full px-4 py-3 border border-[#E8E4DD] rounded-lg text-[#2C2416] placeholder-[#B8B0A4] focus:outline-none focus:ring-2 focus:ring-[#B8926A]/50 focus:border-[#B8926A] transition-colors"
              />
            </div>

            <div>
              <label for="role" class="block text-sm font-medium text-[#2C2416] mb-1">你的身份</label>
              <select
                id="role"
                name="role"
                class="w-full px-4 py-3 border border-[#E8E4DD] rounded-lg text-[#2C2416] bg-white focus:outline-none focus:ring-2 focus:ring-[#B8926A]/50 focus:border-[#B8926A] transition-colors"
              >
                <option value="">請選擇</option>
                <option value="individual">個人使用</option>
                <option value="enterprise">企業導入</option>
              </select>
            </div>

            <div>
              <label for="scenario" class="block text-sm font-medium text-[#2C2416] mb-1">一句話描述你的場景（選填）</label>
              <input
                type="text"
                id="scenario"
                name="scenario"
                placeholder="例：每週 5 場客戶會議，會後花 1 小時整理筆記"
                class="w-full px-4 py-3 border border-[#E8E4DD] rounded-lg text-[#2C2416] placeholder-[#B8B0A4] focus:outline-none focus:ring-2 focus:ring-[#B8926A]/50 focus:border-[#B8926A] transition-colors"
              />
            </div>

            <label class="flex items-start gap-2 cursor-pointer">
              <input
                type="checkbox"
                id="subscribe-newsletter"
                class="mt-1 w-4 h-4 rounded border-[#E8E4DD] text-[#B8926A] focus:ring-[#B8926A]/50"
              />
              <span class="text-sm text-[#5C5144]">同時訂閱每週 AI 工作流電子報</span>
            </label>

            <button
              type="submit"
              class="w-full px-8 py-3.5 bg-[#B8926A] text-white text-lg font-medium rounded-lg hover:bg-[#A67D55] hover:shadow-lg transition-all duration-200"
            >
              我有興趣
            </button>

            <p class="text-xs text-[#8B7355] text-center">不會寄垃圾信，有進展才會通知你。</p>
          </form>

          <!-- Success message (hidden by default) -->
          <div id="success-message" class="hidden text-center py-6">
            <div class="w-14 h-14 rounded-full bg-[#059669]/10 flex items-center justify-center mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[#059669]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-[#2C2416] mb-1">收到了！</h3>
            <p class="text-[#5C5144]">有進展會第一時間通知你。<br />想聊具體想法？直接<a href="mailto:mail@yu-wenhao.com" class="text-[#B8926A] hover:underline">寫信給我</a>。</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    declare global { interface Window { umami?: { track: (event: string, data?: Record<string, unknown>) => void } } }
    const form = document.getElementById('survey-form') as HTMLFormElement;
    const successMessage = document.getElementById('success-message');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (submitBtn.disabled) return;
      submitBtn.disabled = true;
      submitBtn.textContent = '送出中...';

      const email = (document.getElementById('email') as HTMLInputElement).value;
      const role = (document.getElementById('role') as HTMLSelectElement).value;
      const scenario = (document.getElementById('scenario') as HTMLInputElement).value;
      const subscribeNewsletter = (document.getElementById('subscribe-newsletter') as HTMLInputElement).checked;

      // Track with Umami
      window.umami?.track('meeting_tool_survey_submit', { role, has_scenario: !!scenario, subscribe_newsletter: subscribeNewsletter });

      // Submit to Kit (ConvertKit) + own backend in parallel
      const dbPayload = {
        survey_id: 'meeting-tool',
        email,
        role: role || null,
        scenario: scenario || null
      };

      async function submitToDb(retries = 3): Promise<void> {
        for (let i = 0; i < retries; i++) {
          try {
            const res = await fetch('https://yu-wenhao-api.calmisland-ea7fe91e.japaneast.azurecontainerapps.io/api/survey/submit', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(dbPayload)
            });
            if (res.ok) return;
          } catch {}
          if (i < retries - 1) await new Promise(r => setTimeout(r, 1000 * (i + 1)));
        }
      }

      try {
        const [kitRes] = await Promise.all([
          fetch('https://api.convertkit.com/v3/forms/9187469/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              api_key: 'qt8e63EHDagr2wBzMPUcFw',
              email,
              fields: {
                role: role || 'not specified',
                scenario: scenario || ''
              }
            })
          }),
          submitToDb()
        ]);

        if (kitRes.ok) {
          // Tag + optional newsletter subscribe via backend (single call)
          const API_BASE = 'https://yu-wenhao-api.calmisland-ea7fe91e.japaneast.azurecontainerapps.io';
          fetch(`${API_BASE}/api/newsletter/subscribe-form?email=${encodeURIComponent(email)}&source=survey&subscribe_newsletter=${subscribeNewsletter}`, {
            method: 'POST',
          }).catch(() => {});
          form.classList.add('hidden');
          successMessage?.classList.remove('hidden');
        } else {
          alert('送出失敗，請稍後再試。');
          submitBtn.disabled = false;
          submitBtn.textContent = '我有興趣';
        }
      } catch {
        alert('網路錯誤，請稍後再試。');
        submitBtn.disabled = false;
        submitBtn.textContent = '我有興趣';
      }
    });
  </script>
</BaseLayout>
