---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = '1 對 1 教學 — AI 工作流、知識管理、Claude Code';
const description = '4 小時 × 1 對 1 教學，把 AI 工作流、目標管理、知識管理、Claude Code 真正裝進你的日常。NT$8,000，實體（竹北 JustCo）。';

// API / integration config — use localhost in dev, production API otherwise
const API_BASE = import.meta.env.DEV
  ? 'http://localhost:8000'
  : 'https://yu-wenhao-api.calmisland-ea7fe91e.japaneast.azurecontainerapps.io';
const CALENDLY_URL = 'https://calendly.com/mail-yu-wenhao/tutoring_in_person';
const STRIPE_PUBLISHABLE_KEY = import.meta.env.DEV
  ? 'pk_test_51PmX2qFW1q3vb1jMNG2jQfGnhhYzz7w1xkyPzXqZ0sJkc3yOUZ3rdYzaatLsXkIOBQ6gSwF7fgqwH0fgSNmEyhJ700BEN3aelo'
  : 'pk_live_51PmX2qFW1q3vb1jMfoOjXuYqYE4CwqECfssR63nDkcDDWOvScuZqih8kOMR1aOHZhLc1yiUXluQ1W20hTnLMlgsI00RHBTIUle';
const JUSTCO_ADDRESS = '302 新竹縣竹北市高鐵東二路 6 號 5-6 樓';
const JUSTCO_MAP_URL = 'https://maps.google.com/?q=' + encodeURIComponent('JustCo 竹北 高鐵東二路6號');
---

<BaseLayout title={title} description={description} hideLanguageSwitcher={true} noindex={true}>
  {/* 砍掉的 5 個 sections（Outcomes / How it works / Who it's for / Why me / Testimonials）
      已存檔於 docs/in-progress/tutoring-page-sections-archive.md，未來公開時可復用 */}

  <!-- Split layout: Info (left) + Booking state machine (right) -->
  <section id="tutoring-cta" class="py-12 md:py-16 lg:py-20 bg-[#F5F1EB]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,_1fr)_minmax(0,_1.15fr)] gap-10 lg:gap-14 items-start">

        <!-- LEFT: Info -->
        <div class="lg:sticky lg:top-24">
          <p class="text-sm md:text-base font-medium text-[#B8926A] mb-4 tracking-wide uppercase">1:1 Tutoring</p>
          <h1 class="text-[1.75rem] md:text-[2.25rem] lg:text-[2.75rem] font-bold text-[#2C2416] leading-[1.15] tracking-[-0.02em] mb-5">
            4 小時 × 1 對 1，<br />把 AI 工作流裝進你的日常。
          </h1>
          <p class="text-base md:text-lg leading-relaxed text-[#5C5144]">
            給想轉型的工程師、自由接案者，以及想把 AI 認真用起來的人 — 我陪你從零建一套每天會跑、會持續複利的工作系統。
          </p>

          <div class="mt-6 flex flex-wrap items-center gap-4 md:gap-5 text-sm md:text-base text-[#5C5144]">
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 md:w-5 md:h-5 text-[#B8926A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              4 小時
            </span>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 md:w-5 md:h-5 text-[#B8926A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
              竹北 JustCo
            </span>
            <span class="flex items-center gap-2 font-medium text-[#2C2416]">
              NT$8,000
            </span>
          </div>

          <div class="mt-4 space-y-2 text-sm md:text-base text-[#5C5144] leading-relaxed">
            <p>
              <span class="text-[#8B7355] text-xs md:text-sm mr-2">包含</span>
              AI 工作流 · 目標與專案管理 · Obsidian 知識庫 · Claude Code 環境
            </p>
            <p>
              <span class="text-[#8B7355] text-xs md:text-sm mr-2">流程</span>
              30 分鐘釐清場景 → 3 小時手把手建系統 → 30 分鐘收斂下一步
            </p>
          </div>

          <!-- Mobile-only CTA: scrolls to Calendly below -->
          <div class="mt-8 lg:hidden">
            <a href="#booking-widget" class="inline-flex items-center justify-center px-8 py-4 bg-[#B8926A] text-white text-base font-medium rounded-full hover:bg-[#A67D55] hover:shadow-lg transition-all duration-200" data-umami-event="tutoring_hero_cta">
              預約時段 &rarr;
            </a>
          </div>

          <p class="mt-8 text-sm text-[#8B7355]">
            需要改期或取消，請直接聯絡我：<a href="mailto:mail@yu-wenhao.com" class="text-[#5C5144] hover:text-[#B8926A] underline">mail@yu-wenhao.com</a>
          </p>
        </div>

        <!-- RIGHT: Booking state machine -->
        <div id="booking-widget">

          <!-- STATE 1: Calendly widget (select time) -->
          <div id="state-select" class="bg-white rounded-2xl shadow-sm border border-[#E8E4DD] p-3 md:p-4">
            <div id="calendly-inline-widget" style="min-width:320px;height:700px;" data-auto-load="false"></div>
          </div>

      <!-- STATE 2: Payment (Stripe Embedded Checkout) -->
      <div id="state-payment" class="hidden bg-white rounded-2xl shadow-sm border border-[#E8E4DD] overflow-hidden">
        <div class="p-5 md:p-6 border-b border-[#E8E4DD]">
          <div class="flex items-start justify-between gap-4 mb-3 flex-wrap">
            <div>
              <p class="text-xs font-medium text-[#B8926A] mb-1 tracking-wide uppercase">時段已預留</p>
              <p id="payment-summary" class="text-base md:text-lg font-semibold text-[#2C2416]">載入中...</p>
            </div>
            <div class="text-right">
              <p class="text-xs text-[#8B7355]">剩餘時間</p>
              <p id="payment-countdown" class="text-xl font-bold text-[#2C2416] tabular-nums">15:00</p>
            </div>
          </div>
          <p class="text-xs text-[#5C5144] bg-[#F5F1EB] rounded-lg p-2.5">
            ⚠ 請於時間內完成付款以確認預約。未完成付款時段將自動釋放。
          </p>
        </div>
        <div id="stripe-checkout-mount" class="p-3 md:p-4"></div>
      </div>

      <!-- STATE 3: Confirmed -->
      <div id="state-confirmed" class="hidden bg-white rounded-2xl shadow-sm border border-[#E8E4DD] p-6 md:p-8">
          <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#B8926A]/10 mb-4">
              <svg class="w-8 h-8 text-[#B8926A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
            </div>
            <h3 class="text-2xl md:text-3xl font-bold text-[#2C2416] mb-2">預約成功！</h3>
            <p class="text-[#5C5144]">期待和你見面。</p>
          </div>

          <div class="space-y-4 mb-8">
            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-[#F5F1EB] flex items-center justify-center">
                <svg class="w-5 h-5 text-[#B8926A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/></svg>
              </div>
              <div>
                <p class="text-sm text-[#8B7355]">時間</p>
                <p id="confirmed-time" class="text-base md:text-lg font-semibold text-[#2C2416]">—</p>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-[#F5F1EB] flex items-center justify-center">
                <svg class="w-5 h-5 text-[#B8926A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
              </div>
              <div class="min-w-0">
                <p class="text-sm text-[#8B7355]">地點</p>
                <p class="text-base md:text-lg font-semibold text-[#2C2416]">JustCo 竹北高鐵站</p>
                <p class="text-sm text-[#5C5144]">{JUSTCO_ADDRESS}</p>
                <a href={JUSTCO_MAP_URL} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-[#B8926A] hover:underline mt-1">
                  在 Google Maps 開啟 →
                </a>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-[#F5F1EB] flex items-center justify-center">
                <svg class="w-5 h-5 text-[#B8926A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z"/></svg>
              </div>
              <div>
                <p class="text-sm text-[#8B7355]">付款</p>
                <p class="text-base md:text-lg font-semibold text-[#2C2416]">NT$8,000 <span class="text-[#B8926A]">✓</span></p>
                <a id="confirmed-receipt" href="#" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-[#B8926A] hover:underline mt-1 hidden">
                  查看收據 →
                </a>
              </div>
            </div>
          </div>

          <div class="bg-[#F5F1EB] rounded-lg p-4 md:p-5 mb-6">
            <p class="text-sm font-medium text-[#2C2416] mb-2">接下來會收到的 email</p>
            <ul class="text-sm text-[#5C5144] space-y-1">
              <li>• 付款收據（Stripe，幾分鐘內）</li>
              <li>• 上課前 24 小時提醒（Calendly）</li>
            </ul>
          </div>

          <p class="text-sm text-[#8B7355] text-center">
            建議將此頁面加入書籤，隨時可回來查看
          </p>
      </div>

      <!-- STATE 4: Expired -->
      <div id="state-expired" class="hidden bg-white rounded-2xl shadow-sm border border-[#E8E4DD] p-8 md:p-10 text-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#E8E4DD] mb-4">
            <svg class="w-8 h-8 text-[#8B7355]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
          </div>
          <h3 class="text-2xl md:text-3xl font-bold text-[#2C2416] mb-2">時段已釋放</h3>
          <p class="text-[#5C5144] mb-6">
            你預留的時段因未完成付款已釋放，歡迎重新預約。
          </p>
          <button type="button" id="expired-retry" class="inline-flex items-center justify-center px-8 py-4 bg-[#B8926A] text-white text-base md:text-lg font-medium rounded-full hover:bg-[#A67D55] hover:shadow-lg hover:scale-105 transition-all duration-200">
            重新預約 →
          </button>
      </div>

      <!-- STATE 5: Error -->
      <div id="state-error" class="hidden bg-white rounded-2xl shadow-sm border border-[#E8E4DD] p-8 md:p-10 text-center">
          <h3 class="text-xl font-bold text-[#2C2416] mb-2">發生問題</h3>
          <p id="error-message" class="text-[#5C5144] mb-6">—</p>
          <div class="flex flex-wrap gap-3 justify-center">
            <button type="button" id="error-retry" class="inline-flex items-center justify-center px-6 py-3 bg-[#B8926A] text-white text-base font-medium rounded-full hover:bg-[#A67D55] transition-all duration-200">
              重新開始
            </button>
            <a href="mailto:mail@yu-wenhao.com?subject=1:1 教學預約遇到問題" class="inline-flex items-center justify-center px-6 py-3 border-2 border-[#B8926A] text-[#B8926A] text-base font-medium rounded-full hover:bg-[#B8926A] hover:text-white transition-all duration-200">
              寫信聯絡我
            </a>
          </div>
      </div>

        </div><!-- /#booking-widget -->
      </div><!-- /.grid -->
    </div>
  </section>

  <!-- External scripts -->
  <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  <script is:inline src="https://js.stripe.com/v3/" async></script>

  <!-- State machine -->
  <script define:vars={{ API_BASE, CALENDLY_URL, STRIPE_PUBLISHABLE_KEY, JUSTCO_ADDRESS, IS_DEV: import.meta.env.DEV }}>
    const STORAGE_KEY = 'tutoring_booking_id';
    const STATES = ['select', 'payment', 'confirmed', 'expired', 'error'];
    let pollTimer = null;
    let countdownTimer = null;
    let checkoutInstance = null;

    const $ = (id) => document.getElementById(id);

    function showState(name) {
      STATES.forEach((s) => {
        const el = $(`state-${s}`);
        if (el) el.classList.toggle('hidden', s !== name);
      });
    }

    function showError(msg) {
      const errEl = $('error-message');
      if (errEl) errEl.textContent = msg || '請稍後再試或寫信給我。';
      showState('error');
    }

    function resetToSelect() {
      localStorage.removeItem(STORAGE_KEY);
      clearTimers();
      showState('select');
      loadCalendly();
      window.umami?.track('tutoring_reset_to_select');
    }

    function clearTimers() {
      if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
      if (countdownTimer) { clearInterval(countdownTimer); countdownTimer = null; }
    }

    function formatDateTime(iso) {
      const d = new Date(iso);
      const days = ['日', '一', '二', '三', '四', '五', '六'];
      const pad = (n) => String(n).padStart(2, '0');
      const end = new Date(d.getTime() + 4 * 60 * 60 * 1000);
      return `${d.getFullYear()}/${pad(d.getMonth() + 1)}/${pad(d.getDate())}（週${days[d.getDay()]}）${pad(d.getHours())}:${pad(d.getMinutes())}–${pad(end.getHours())}:${pad(end.getMinutes())}`;
    }

    // --- Calendly ---
    function loadCalendly() {
      const container = $('calendly-inline-widget');
      if (!container) return;
      container.innerHTML = '';
      // Calendly widget.js exposes window.Calendly.initInlineWidget
      const init = () => {
        if (window.Calendly) {
          window.Calendly.initInlineWidget({
            url: CALENDLY_URL,
            parentElement: container,
            prefill: {},
            utm: {}
          });
        } else {
          setTimeout(init, 200);
        }
      };
      init();
    }

    // Listen for Calendly event_scheduled postMessage
    window.addEventListener('message', (e) => {
      if (!e.data || typeof e.data !== 'object') return;
      if (e.data.event === 'calendly.event_scheduled') {
        const invitee_uri = e.data.payload?.invitee?.uri;
        if (!invitee_uri) {
          showError('Calendly 未提供 invitee URI');
          return;
        }
        window.umami?.track('tutoring_slot_selected');
        handleSlotSelected(invitee_uri);
      }
    });

    // --- Flow handlers ---
    async function handleSlotSelected(invitee_uri) {
      showState('payment');
      try {
        const res = await fetch(`${API_BASE}/api/tutoring/create-checkout`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ invitee_uri })
        });
        const json = await res.json();
        if (!json.success) throw new Error(json.error || 'Checkout creation failed');

        const { booking_id, client_secret } = json.data;
        localStorage.setItem(STORAGE_KEY, booking_id);
        await mountCheckout(client_secret, booking_id);
        hydratePaymentSummary(booking_id);
        startCountdown(15 * 60);
        startPolling(booking_id);
      } catch (err) {
        console.error('[tutoring] create-checkout failed:', err);
        if (IS_DEV) {
          console.warn('[tutoring] dev mode: backend likely not running on :8000. Returning to select state.');
          resetToSelect();
        } else {
          showError(String(err?.message || err));
        }
      }
    }

    async function mountCheckout(clientSecret, bookingId) {
      if (!window.Stripe) {
        await new Promise((resolve) => {
          const check = () => window.Stripe ? resolve() : setTimeout(check, 200);
          check();
        });
      }
      const stripe = window.Stripe(STRIPE_PUBLISHABLE_KEY);
      const mount = $('stripe-checkout-mount');
      if (!mount) return;
      mount.innerHTML = '';
      if (checkoutInstance) {
        try { checkoutInstance.destroy(); } catch {}
      }
      checkoutInstance = await stripe.initEmbeddedCheckout({
        clientSecret,
        onComplete: () => {
          window.umami?.track('tutoring_payment_complete');
          // Polling will pick up status=paid
        }
      });
      checkoutInstance.mount('#stripe-checkout-mount');
    }

    async function hydratePaymentSummary(bookingId) {
      try {
        const res = await fetch(`${API_BASE}/api/tutoring/status/${bookingId}`);
        const json = await res.json();
        if (!json.success) return;
        const { scheduled_at } = json.data;
        if (scheduled_at) {
          const el = $('payment-summary');
          if (el) el.textContent = formatDateTime(scheduled_at);
        }
      } catch {
        // non-fatal: summary will stay as "載入中..." but payment still works
      }
    }

    function startCountdown(seconds) {
      if (countdownTimer) clearInterval(countdownTimer);
      let remaining = seconds;
      const el = $('payment-countdown');
      const render = () => {
        const m = Math.floor(remaining / 60);
        const s = remaining % 60;
        if (el) el.textContent = `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      };
      render();
      countdownTimer = setInterval(() => {
        remaining -= 1;
        render();
        if (remaining <= 0) {
          clearInterval(countdownTimer);
          // Don't mark expired from client; let backend determine
        }
      }, 1000);
    }

    function startPolling(bookingId) {
      if (pollTimer) clearInterval(pollTimer);
      const maxAttempts = 150; // 5 minutes at 2s intervals
      let attempts = 0;
      pollTimer = setInterval(async () => {
        attempts++;
        if (attempts > maxAttempts) {
          clearInterval(pollTimer);
          return;
        }
        try {
          const res = await fetch(`${API_BASE}/api/tutoring/status/${bookingId}`);
          const json = await res.json();
          if (!json.success) return;
          const { status, scheduled_at, stripe_receipt_url } = json.data;
          if (status === 'paid') {
            clearTimers();
            renderConfirmed(scheduled_at, stripe_receipt_url);
          } else if (status === 'expired' || status === 'canceled') {
            clearTimers();
            localStorage.removeItem(STORAGE_KEY);
            showState('expired');
          }
        } catch {
          // ignore transient errors, keep polling
        }
      }, 2000);
    }

    function renderConfirmed(scheduledAt, receiptUrl) {
      const timeEl = $('confirmed-time');
      if (timeEl) timeEl.textContent = formatDateTime(scheduledAt);
      const receiptEl = $('confirmed-receipt');
      if (receiptEl && receiptUrl) {
        receiptEl.href = receiptUrl;
        receiptEl.classList.remove('hidden');
      }
      showState('confirmed');
      window.umami?.track('tutoring_booking_confirmed');
    }

    // --- Recovery on page load ---
    async function restoreState() {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (!stored) {
        showState('select');
        loadCalendly();
        return;
      }
      try {
        const res = await fetch(`${API_BASE}/api/tutoring/status/${stored}`);
        const json = await res.json();
        if (!json.success) {
          resetToSelect();
          return;
        }
        const { status, scheduled_at, stripe_receipt_url, hold_expires_at } = json.data;
        if (status === 'paid') {
          renderConfirmed(scheduled_at, stripe_receipt_url);
          return;
        }
        if (status === 'expired' || status === 'canceled') {
          localStorage.removeItem(STORAGE_KEY);
          showState('expired');
          return;
        }
        if (status === 'pending') {
          // Still within hold window? Recreate checkout
          const expiresAt = new Date(hold_expires_at).getTime();
          const now = Date.now();
          if (expiresAt <= now) {
            localStorage.removeItem(STORAGE_KEY);
            showState('expired');
            return;
          }
          // Rebuild payment UI — need a fresh client_secret? We don't have it.
          // For now, show expired and let user restart. Future: add a rehydrate endpoint.
          resetToSelect();
        }
      } catch {
        resetToSelect();
      }
    }

    // --- Wire buttons ---
    $('expired-retry')?.addEventListener('click', resetToSelect);
    $('error-retry')?.addEventListener('click', resetToSelect);

    // --- Handle success URL (?success=1&session_id=...) ---
    const params = new URLSearchParams(window.location.search);
    if (params.get('success') === '1') {
      const sid = params.get('session_id');
      // Strip query from URL
      const cleanUrl = window.location.pathname + window.location.hash;
      window.history.replaceState({}, '', cleanUrl);
      // Restore from storage (should already be set); polling will flip to confirmed
      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored) {
        showState('payment');
        startPolling(stored);
      } else {
        showState('select');
        loadCalendly();
      }
    } else {
      restoreState();
    }

    // Umami: CTA visible
    const ctaSection = document.getElementById('tutoring-cta');
    if (ctaSection) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            window.umami?.track('tutoring_cta_visible');
            observer.disconnect();
          }
        });
      }, { threshold: 0.3 });
      observer.observe(ctaSection);
    }
  </script>
</BaseLayout>
