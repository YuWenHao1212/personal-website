---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'About';
const description = "I'm WenHao. PM turned solo builder. I use AI to ship products, design systems, and document the entire process.";

const timeline = [
  { year: '2023', text: "Minerva University — Master's in Decision Analysis (MDA)" },
  { year: '2025.05', text: 'Claude Code Day 1 — started building products solo with AI' },
  { year: '2025.08', text: 'Graduated from Minerva MDA' },
  { year: '2025.12', text: 'AI Resume Advisor launched (full SaaS)' },
  { year: '2026.01', text: 'Chrome / Edge Extension launched, started writing on FB and personal site' },
  { year: '2026.02', text: 'NeatToolkit launched — 4,000 users on day one, multiple articles ranking Google Top 3' },
];

const products = [
  {
    name: 'AI Resume Advisor',
    description: 'SaaS + Chrome/Edge Extension for AI-powered resume analysis',
    url: 'https://airesumeadvisor.com/',
  },
  {
    name: 'NeatToolkit',
    description: 'Free AI tool site — 4,000 users on launch day',
    url: 'https://www.neatoolkit.com/en',
  },
  {
    name: 'yu-wenhao.com',
    description: 'Personal site + blog — 60K+ monthly visitors, built in 2 days',
    url: 'https://yu-wenhao.com/en/',
  },
];

const techStack = [
  'Claude Code / Agentic Coding',
  'Astro + Tailwind CSS',
  'Next.js + React',
  'FastAPI + Python',
  'Azure (Container Apps, Static Web Apps)',
  'Chrome/Edge Extension Development',
  'SEO & Content Strategy',
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="py-20 md:py-28 lg:py-32 bg-[#F5F1EB]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
        <img
          src="/images/hero.webp"
          alt="WenHao Yu"
          width="240"
          height="240"
          class="w-40 h-40 md:w-56 md:h-56 lg:w-64 lg:h-64 rounded-full object-cover shadow-lg flex-shrink-0"
        />
        <div>
          <h1 class="text-[2rem] md:text-[2.75rem] lg:text-[3.5rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-4">
            I'm WenHao
          </h1>
          <p class="text-xl md:text-2xl leading-relaxed text-[#5C5144] mb-6">
            15+ years in tech — engineer, product manager, data analyst. Now I ship full-stack products solo with AI, from idea to launch.
          </p>
          <div class="flex flex-wrap gap-3 text-sm text-[#8B7355]">
            <span class="px-3 py-1 bg-[#B8926A]/10 rounded-full">Claude Code Day 1 User</span>
            <span class="px-3 py-1 bg-[#B8926A]/10 rounded-full">Minerva University M.S.</span>
            <span class="px-3 py-1 bg-[#B8926A]/10 rounded-full">Full-Stack Builder</span>
            <a href="https://github.com/YuWenHao1212" target="_blank" rel="noopener noreferrer" class="px-3 py-1 bg-[#B8926A]/10 rounded-full hover:bg-[#B8926A]/20 transition-colors">GitHub</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Story + Belief -->
  <section class="py-20 md:py-28 lg:py-32 bg-[#FFFDF9]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-[2rem] md:text-[2.5rem] lg:text-[3rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-8 md:mb-10">
          My Story
        </h2>
        <div class="space-y-5 text-base md:text-lg lg:text-xl leading-relaxed text-[#5C5144]">
          <p>Over a decade in engineering, product management, and data — I knew how to build, ship, and measure. But most of my energy went into alignment, not execution.</p>
          <p>In 2023, I enrolled in Minerva University's master's program to reset.</p>
          <p class="text-lg md:text-xl lg:text-2xl font-semibold text-[#2C2416] py-2">
            Then AI hit a tipping point.
          </p>
          <p>In May 2025, Claude Code launched and I was one of the first to use it. Four months — a full SaaS (<a href="https://airesumeadvisor.com/" target="_blank" rel="noopener noreferrer" class="text-[#B8926A] hover:underline">AI Resume Advisor</a>). Two weeks — <a href="https://chromewebstore.google.com/detail/ai-resume-advisor-%E2%80%94-linke/iafpieelbhhlmhgjekflneciffoonkgf" target="_blank" rel="noopener noreferrer" class="text-[#B8926A] hover:underline">Chrome</a> and <a href="https://microsoftedge.microsoft.com/addons/detail/ai-resume-advisor-%E2%80%94-linke/ekhlndlifglmicdphldpciifohloeaek" target="_blank" rel="noopener noreferrer" class="text-[#B8926A] hover:underline">Edge</a> Extensions. Three days — <a href="https://www.neatoolkit.com/en" target="_blank" rel="noopener noreferrer" class="text-[#B8926A] hover:underline">NeatToolkit</a>, 4,000 users on day one. This site, two days.</p>
          <p class="text-lg md:text-xl lg:text-2xl font-semibold text-[#2C2416] py-2">
            All solo.
          </p>
          <p>The real shift: I can now take a product from idea to launch — design, frontend, backend, deployment, SEO — without waiting for a team.</p>
        </div>

        <!-- Belief as closing blockquote -->
        <div class="mt-10 md:mt-14 pl-6 md:pl-8 py-4 md:py-6 border-l-4 border-[#B8926A]">
          <p class="text-[1.5rem] md:text-[2rem] lg:text-[2.5rem] font-bold text-[#2C2416] leading-[1.2] tracking-[-0.02em] mb-4">
            Direction over speed. Systems over goals.
          </p>
          <p class="text-lg md:text-xl leading-relaxed text-[#5C5144]">
            Most people chase AI tools without knowing what to build. I do it the other way around — find the direction first, build a compounding workflow, and use AI as the lever. Repeat the simple things. Let time do the rest.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What I Bring -->
  <section class="py-20 md:py-28 lg:py-32 bg-[#F5F1EB]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-[2rem] md:text-[2.5rem] lg:text-[3rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-12 md:mb-16">
          What I Bring
        </h2>
        <div class="flex flex-wrap gap-3">
          <span class="px-4 py-2 bg-white border border-[#E8E4DD] rounded-full text-base md:text-lg text-[#2C2416]">Product Development (0 → 1)</span>
          <span class="px-4 py-2 bg-white border border-[#E8E4DD] rounded-full text-base md:text-lg text-[#2C2416]">AI Integration & Workflow Automation</span>
          <span class="px-4 py-2 bg-white border border-[#E8E4DD] rounded-full text-base md:text-lg text-[#2C2416]">Growth & Content Strategy</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-20 md:py-28 lg:py-32 bg-[#FFFDF9]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-[2rem] md:text-[2.5rem] lg:text-[3rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-12 md:mb-16">
          The Path
        </h2>
        <div class="space-y-0">
          {timeline.map((item, index) => (
            <div class="flex gap-6 md:gap-8">
              <div class="flex flex-col items-center">
                <div class="w-3 h-3 rounded-full bg-[#B8926A] flex-shrink-0 mt-2"></div>
                {index < timeline.length - 1 && (
                  <div class="w-px flex-1 bg-[#D9D4CB] my-1"></div>
                )}
              </div>
              <div class="pb-8 md:pb-10">
                <p class="text-sm md:text-base font-semibold text-[#B8926A] mb-1">{item.year}</p>
                <p class="text-base md:text-lg text-[#2C2416]">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="py-20 md:py-28 lg:py-32 bg-[#FFFDF9]">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-[2rem] md:text-[2.5rem] lg:text-[3rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-12 md:mb-16">
        What I've Built
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {products.map((product) => (
          <a
            href={product.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-white border border-[#E8E4DD] rounded-xl p-6 md:p-8 hover:shadow-lg hover:border-[#B8926A]/30 hover:-translate-y-1 transition-all duration-300"
          >
            <h3 class="text-xl md:text-2xl font-semibold text-[#2C2416] mb-3 group-hover:text-[#B8926A] transition-colors">{product.name}</h3>
            <p class="text-base md:text-lg leading-relaxed text-[#5C5144]">{product.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-20 md:py-28 lg:py-32 bg-[#F5F1EB]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-[2rem] md:text-[2.5rem] lg:text-[3rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-12 md:mb-16">
          Tech & Tools
        </h2>
        <div class="flex flex-wrap gap-3">
          {techStack.map((tech) => (
            <span class="px-4 py-2 bg-white border border-[#E8E4DD] rounded-full text-base md:text-lg text-[#2C2416]">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 md:py-28 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mx-auto bg-[#F5F1EB] rounded-2xl p-10 md:p-14 lg:p-16 text-center">
        <h2 class="text-[1.75rem] md:text-[2.25rem] lg:text-[2.75rem] font-bold text-[#2C2416] leading-[1.1] tracking-[-0.02em] mb-4">
          Let's Connect
        </h2>
        <p class="text-lg md:text-xl text-[#5C5144] mb-8 md:mb-10 leading-relaxed">
          Collaboration, AI, or just saying hi — I'd love to hear from you.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href="https://www.linkedin.com/in/hence/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-4 bg-[#B8926A] text-white text-base md:text-lg font-medium rounded-full hover:bg-[#A67D55] hover:shadow-lg hover:scale-105 transition-all duration-200"
          >
            Connect on LinkedIn
          </a>
          <a
            href="mailto:mail@yu-wenhao.com"
            class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#B8926A] text-[#B8926A] text-base md:text-lg font-medium rounded-full hover:bg-[#B8926A] hover:text-white hover:shadow-md hover:scale-105 transition-all duration-200"
          >
            Email Me
          </a>
          <a
            href="https://github.com/YuWenHao1212"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-4 border-2 border-[#B8926A] text-[#B8926A] text-base md:text-lg font-medium rounded-full hover:bg-[#B8926A] hover:text-white hover:shadow-md hover:scale-105 transition-all duration-200"
          >
            GitHub
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
