---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="問卷回覆">
  <div class="max-w-5xl">

    <!-- Survey selector -->
    <div class="bg-white border border-cream-300 rounded-xl p-4 shadow-sm mb-4">
      <label for="survey-select" class="block text-sm font-medium text-ink-700 mb-2">選擇問卷</label>
      <select id="survey-select" class="w-full md:w-auto px-4 py-2 rounded-lg border border-cream-300 text-base text-ink-900 focus:outline-none focus:border-accent bg-white">
        <option value="meeting-tool">Meeting Tool Survey</option>
        <option value="workshop-signup-2026-q2">Workshop 報名（2026 Q2）</option>
      </select>
    </div>

    <!-- Stats -->
    <div class="bg-white border border-cream-300 rounded-xl p-6 shadow-sm mb-6">
      <div class="flex items-baseline gap-3">
        <span id="total-count" class="text-4xl font-bold text-ink-900">—</span>
        <span class="text-ink-500">筆回覆</span>
      </div>
      <div id="role-breakdown" class="mt-2 text-sm text-ink-400"></div>
    </div>

    <!-- Table -->
    <div class="bg-white border border-cream-300 rounded-xl shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-cream-100">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-ink-500">#</th>
              <th class="text-left px-4 py-3 font-medium text-ink-500">Email</th>
              <th class="text-left px-4 py-3 font-medium text-ink-500">角色</th>
              <th class="text-left px-4 py-3 font-medium text-ink-500">使用情境</th>
              <th class="text-left px-4 py-3 font-medium text-ink-500">日期</th>
              <th class="text-left px-4 py-3 font-medium text-ink-500">Follow-up</th>
            </tr>
          </thead>
          <tbody id="responses-body"></tbody>
        </table>
      </div>
      <div id="empty-state" class="hidden text-center py-8 text-ink-400">尚無回覆資料。</div>
      <div id="loading-state" class="text-center py-8 text-ink-400">載入中...</div>
    </div>

  </div>

  <script>
    function escapeHtml(str: string): string {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function renderSurveyData(data: any) {
      const responses = data.data.responses;
      const totalEl = document.getElementById('total-count')!;
      const roleEl = document.getElementById('role-breakdown')!;
      const bodyEl = document.getElementById('responses-body')!;
      const emptyEl = document.getElementById('empty-state')!;
      const loadingEl = document.getElementById('loading-state')!;

      loadingEl.classList.add('hidden');
      totalEl.textContent = data.data.total.toString();

      // Role breakdown
      const roles: Record<string, number> = {};
      for (const r of responses) {
        const role = r.role || '未填寫';
        roles[role] = (roles[role] || 0) + 1;
      }
      roleEl.textContent = Object.entries(roles)
        .map(([k, v]) => `${k}: ${v}`)
        .join(' · ');

      if (responses.length === 0) {
        emptyEl.classList.remove('hidden');
        return;
      }

      bodyEl.innerHTML = responses
        .map((r: any, i: number) => {
          const date = new Date(r.created_at).toLocaleDateString('zh-TW', {
            month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'
          });
          const followupSent = r.followup_sent_at;
          const followupCell = followupSent
            ? `<span class="text-green-600 text-xs font-medium">已寄 ${new Date(followupSent).toLocaleDateString('zh-TW', { month: 'short', day: 'numeric' })}</span>`
            : `<button data-email="${escapeHtml(r.email)}" class="followup-btn px-2 py-1 text-xs bg-accent text-white rounded hover:bg-accent-hover transition-colors">標記已寄</button>`;
          return `
            <tr class="border-t border-cream-300 hover:bg-cream-50 transition-colors">
              <td class="px-4 py-3 text-ink-400">${i + 1}</td>
              <td class="px-4 py-3 text-ink-900">${escapeHtml(r.email)}</td>
              <td class="px-4 py-3 text-ink-600">${escapeHtml(r.role || '—')}</td>
              <td class="px-4 py-3 text-ink-600 max-w-[300px]">
                <span class="block truncate" title="${escapeHtml(r.scenario || '')}">${escapeHtml(r.scenario || '—')}</span>
              </td>
              <td class="px-4 py-3 text-ink-400 whitespace-nowrap">${date}</td>
              <td class="px-4 py-3">${followupCell}</td>
            </tr>
          `;
        })
        .join('');

      // Attach click handlers for followup buttons
      const admin = (window as any).__admin;
      const surveyId = (document.getElementById('survey-select') as HTMLSelectElement).value;
      document.querySelectorAll('.followup-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const target = e.target as HTMLButtonElement;
          const email = target.dataset.email;
          const key = admin?.getKey();
          if (!email || !key) return;

          target.textContent = '...';
          target.disabled = true;

          try {
            const res = await fetch(
              `${admin.API_BASE}/api/survey/responses/${surveyId}/${encodeURIComponent(email)}/followup?key=${encodeURIComponent(key)}`,
              { method: 'PATCH' }
            );
            if (res.ok) {
              target.outerHTML = `<span class="text-green-600 text-xs font-medium">已寄</span>`;
            } else {
              target.textContent = '失敗';
            }
          } catch {
            target.textContent = '失敗';
          }
        });
      });
    }

    function loadSurveyData() {
      const admin = (window as any).__admin;
      if (!admin) return;

      const key = admin.getKey();
      if (!key) return;

      const surveyId = (document.getElementById('survey-select') as HTMLSelectElement).value;
      const loadingEl = document.getElementById('loading-state')!;
      const emptyEl = document.getElementById('empty-state')!;
      const bodyEl = document.getElementById('responses-body')!;

      // Reset UI before fetch
      loadingEl.textContent = '載入中...';
      loadingEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');
      bodyEl.innerHTML = '';

      fetch(`${admin.API_BASE}/api/survey/responses/${surveyId}?key=${encodeURIComponent(key)}`)
        .then(res => {
          if (!res.ok) throw new Error('Failed to fetch');
          return res.json();
        })
        .then(renderSurveyData)
        .catch(() => {
          loadingEl.textContent = '載入失敗，請重新整理頁面。';
        });
    }

    // Survey dropdown change → reload
    document.getElementById('survey-select')!.addEventListener('change', loadSurveyData);

    // Wait for auth guard to show dashboard
    const observer = new MutationObserver(() => {
      const guard = document.getElementById('admin-auth-guard');
      if (guard && !guard.classList.contains('hidden')) {
        loadSurveyData();
        observer.disconnect();
      }
    });
    observer.observe(document.getElementById('admin-auth-guard')!, { attributes: true });
  </script>
</AdminLayout>
