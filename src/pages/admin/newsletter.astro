---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="電子報">
  <div class="max-w-5xl">

    <!-- Stats cards -->
    <div class="grid gap-4 mb-6" style="grid-template-columns: repeat(4, 1fr);">
      <div class="bg-white border border-cream-300 rounded-xl p-5 shadow-sm">
        <div class="text-sm text-ink-400 mb-1">總訂閱數</div>
        <div class="flex items-baseline gap-2">
          <span id="stat-total" class="text-3xl font-bold text-ink-900">—</span>
          <span id="stat-today" class="text-sm font-medium text-green-600"></span>
        </div>
      </div>
      <div class="bg-white border border-cream-300 rounded-xl p-5 shadow-sm">
        <div class="text-sm text-ink-400 mb-1">電子報訂閱</div>
        <div id="stat-newsletter" class="text-3xl font-bold text-ink-900">—</div>
        <div class="text-xs text-ink-400 mt-1">newsletter-subscriber</div>
      </div>
      <div class="bg-white border border-cream-300 rounded-xl p-5 shadow-sm">
        <div class="text-sm text-ink-400 mb-1">Survey 填單</div>
        <div id="stat-survey" class="text-3xl font-bold text-ink-900">—</div>
        <div class="text-xs text-ink-400 mt-1">AIMeeting Note Tool Survey</div>
      </div>
      <div class="bg-white border border-cream-300 rounded-xl p-5 shadow-sm">
        <div class="text-sm text-ink-400 mb-1">Survey 轉訂閱</div>
        <div id="stat-survey-convert" class="text-3xl font-bold text-ink-900">—</div>
        <div class="text-xs text-ink-400 mt-1">survey-to-newsletter</div>
      </div>
    </div>

    <!-- Trend chart -->
    <div class="bg-white border border-cream-300 rounded-xl p-6 shadow-sm mb-6">
      <div class="flex items-center justify-between mb-2">
        <div>
          <h2 class="text-lg font-semibold text-ink-900">訂閱成長</h2>
          <p class="text-sm text-ink-400">過去 30 天累積訂閱數</p>
        </div>
        <div id="trend-total" class="text-right"></div>
      </div>
      <div id="trend-chart" class="mt-4">
        <div class="text-ink-400 text-sm py-8 text-center">載入中...</div>
      </div>
    </div>

    <!-- Tooltip (hidden, positioned via JS) -->
    <div id="chart-tooltip" class="fixed hidden bg-white border border-cream-300 rounded-lg shadow-lg px-4 py-3 text-sm z-50 pointer-events-none">
      <div id="tooltip-date" class="font-semibold text-ink-900"></div>
      <div id="tooltip-info" class="text-accent"></div>
    </div>

    <!-- Modal -->
    <div id="day-modal" class="fixed inset-0 bg-black/40 hidden z-50 flex items-center justify-center">
      <div class="bg-white rounded-xl shadow-xl w-full max-w-lg mx-4 max-h-[80vh] flex flex-col">
        <div class="flex items-center justify-between px-6 py-4 border-b border-cream-300">
          <h3 id="modal-title" class="text-lg font-semibold text-ink-900"></h3>
          <button id="modal-close" class="text-ink-400 hover:text-ink-700 text-xl leading-none">&times;</button>
        </div>
        <div id="modal-body" class="px-6 py-4 overflow-y-auto flex-1">
          <div class="text-ink-400 text-sm text-center py-4">載入中...</div>
        </div>
        <div id="modal-footer" class="px-6 py-3 border-t border-cream-300 text-sm text-ink-400"></div>
      </div>
    </div>

    <!-- Recent subscribers -->
    <div class="bg-white border border-cream-300 rounded-xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-cream-300">
        <h2 class="text-lg font-semibold text-ink-900">最近訂閱者</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-cream-100">
            <tr>
              <th class="text-left px-4 py-3 font-medium text-ink-500">#</th>
              <th class="text-left px-4 py-3 font-medium text-ink-500">Email</th>
              <th class="text-left px-4 py-3 font-medium text-ink-500">日期</th>
            </tr>
          </thead>
          <tbody id="subscribers-body"></tbody>
        </table>
      </div>
      <div id="loading-state" class="text-center py-8 text-ink-400">載入中...</div>
    </div>

  </div>

  <script>
    const KIT_FORM_ID = '8951335';

    function escapeHtml(str: string): string {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function renderStats(data: any) {
      const { total_subscribers, tags, recent_subscribers } = data.data;
      const loadingEl = document.getElementById('loading-state')!;
      loadingEl.classList.add('hidden');

      document.getElementById('stat-total')!.textContent = total_subscribers.toString();

      const newsletterTag = tags.find((t: any) => t.name === 'newsletter-subscriber');
      const surveyTag = tags.find((t: any) => t.name.includes('AIMeeting'));
      const surveyConvertTag = tags.find((t: any) => t.name === 'survey-to-newsletter');

      document.getElementById('stat-newsletter')!.textContent = newsletterTag ? newsletterTag.count.toString() : '0';
      document.getElementById('stat-survey')!.textContent = surveyTag ? surveyTag.count.toString() : '0';
      document.getElementById('stat-survey-convert')!.textContent = surveyConvertTag ? surveyConvertTag.count.toString() : '0';

      // Recent subscribers table (remove status column)
      const bodyEl = document.getElementById('subscribers-body')!;
      bodyEl.innerHTML = recent_subscribers
        .map((s: any, i: number) => {
          const date = new Date(s.created_at).toLocaleDateString('zh-TW', {
            month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'
          });
          return `
            <tr class="border-t border-cream-300 hover:bg-cream-50 transition-colors">
              <td class="px-4 py-3 text-ink-400">${i + 1}</td>
              <td class="px-4 py-3 text-ink-900">${escapeHtml(s.email)}</td>
              <td class="px-4 py-3 text-ink-400 whitespace-nowrap">${date}</td>
            </tr>
          `;
        })
        .join('');
    }

    function renderTrend(data: any) {
      const { today, trend } = data.data;
      const chartEl = document.getElementById('trend-chart')!;
      const todayEl = document.getElementById('stat-today')!;
      const trendTotalEl = document.getElementById('trend-total')!;

      if (today > 0) {
        todayEl.textContent = `+${today} 今日`;
      }

      // Build cumulative data
      const cumulative: { date: string; total: number }[] = [];
      // Start from total subscribers minus sum of trend counts (= count before the 30-day window)
      const totalSubs = parseInt(document.getElementById('stat-newsletter')!.textContent || '0');
      const trendSum = trend.reduce((sum: number, d: any) => sum + d.count, 0);
      let running = totalSubs - trendSum;

      for (const d of trend) {
        running += d.count;
        cumulative.push({ date: d.date, total: running });
      }

      // Show period growth
      const periodGrowth = trendSum;
      trendTotalEl.innerHTML = `<span class="text-2xl font-bold text-ink-900">${cumulative[cumulative.length - 1].total}</span><br><span class="text-sm text-green-600">+${periodGrowth} (30 天)</span>`;

      // SVG dimensions
      const W = 900;
      const H = 220;
      const padL = 45;
      const padR = 15;
      const padT = 15;
      const padB = 35;
      const chartW = W - padL - padR;
      const chartH = H - padT - padB;

      const values = cumulative.map(d => d.total);
      const minVal = Math.min(...values);
      const maxVal = Math.max(...values);
      const range = maxVal - minVal || 1;

      // Scale functions
      const xScale = (i: number) => padL + (i / (cumulative.length - 1)) * chartW;
      const yScale = (v: number) => padT + chartH - ((v - minVal) / range) * chartH;

      // Build polyline points
      const points = cumulative.map((d, i) => `${xScale(i)},${yScale(d.total)}`).join(' ');

      // Area fill
      const areaPoints = `${xScale(0)},${padT + chartH} ${points} ${xScale(cumulative.length - 1)},${padT + chartH}`;

      // Y-axis labels (4 ticks)
      const yTicks = [0, 0.33, 0.66, 1].map(pct => {
        const val = Math.round(minVal + pct * range);
        const y = yScale(val);
        return `<line x1="${padL}" y1="${y}" x2="${padL + chartW}" y2="${y}" stroke="#EBE6DC" stroke-width="1"/>
                <text x="${padL - 8}" y="${y + 4}" text-anchor="end" fill="#818181" font-size="11">${val}</text>`;
      }).join('');

      // X-axis labels (every 5 days + last)
      const xLabels = cumulative
        .filter((_, i) => i % 5 === 0 || i === cumulative.length - 1)
        .map((d, _, arr) => {
          const i = cumulative.indexOf(d);
          const dt = new Date(d.date + 'T00:00:00');
          const label = `${dt.getMonth() + 1}/${dt.getDate()}`;
          return `<text x="${xScale(i)}" y="${H - 5}" text-anchor="middle" fill="#818181" font-size="11">${label}</text>`;
        }).join('');

      // Dots (interactive)
      const dots = cumulative.map((d, i) => {
        const newCount = trend[i].count;
        return `<circle cx="${xScale(i)}" cy="${yScale(d.total)}" r="5" fill="#CA8A04" stroke="white" stroke-width="2"
                  class="cursor-pointer hover:r-7 transition-all"
                  data-date="${d.date}" data-total="${d.total}" data-new="${newCount}" data-idx="${i}"
                  style="cursor:pointer;" />`;
      }).join('');

      chartEl.innerHTML = `
        <svg viewBox="0 0 ${W} ${H}" class="w-full" style="max-height: 220px;">
          ${yTicks}
          <polygon points="${areaPoints}" fill="#CA8A04" opacity="0.08"/>
          <polyline points="${points}" fill="none" stroke="#CA8A04" stroke-width="2.5" stroke-linejoin="round"/>
          ${dots}
          ${xLabels}
        </svg>
      `;

      // Tooltip on hover
      const tooltip = document.getElementById('chart-tooltip')!;
      const tooltipDate = document.getElementById('tooltip-date')!;
      const tooltipInfo = document.getElementById('tooltip-info')!;

      chartEl.querySelectorAll('circle').forEach(circle => {
        circle.addEventListener('mouseenter', (e) => {
          const el = e.target as SVGCircleElement;
          const dt = new Date(el.dataset.date + 'T00:00:00');
          const dateStr = `${dt.getFullYear()}/${dt.getMonth() + 1}/${dt.getDate()}`;
          tooltipDate.textContent = dateStr;
          tooltipInfo.textContent = `累計: ${el.dataset.total} 人 (+${el.dataset.new} 新增)`;
          tooltip.classList.remove('hidden');
          el.setAttribute('r', '7');
        });

        circle.addEventListener('mousemove', (e: any) => {
          tooltip.style.left = `${e.clientX + 12}px`;
          tooltip.style.top = `${e.clientY - 10}px`;
        });

        circle.addEventListener('mouseleave', (e) => {
          tooltip.classList.add('hidden');
          (e.target as SVGCircleElement).setAttribute('r', '5');
        });

        // Click to show modal
        circle.addEventListener('click', (e) => {
          const el = e.target as SVGCircleElement;
          const date = el.dataset.date!;
          const newCount = parseInt(el.dataset.new || '0');
          showDayModal(date, newCount);
        });
      });
    }

    async function showDayModal(date: string, newCount: number) {
      const modal = document.getElementById('day-modal')!;
      const title = document.getElementById('modal-title')!;
      const body = document.getElementById('modal-body')!;
      const footer = document.getElementById('modal-footer')!;
      const closeBtn = document.getElementById('modal-close')!;

      const dt = new Date(date + 'T00:00:00');
      title.textContent = `${dt.getFullYear()}/${dt.getMonth() + 1}/${dt.getDate()} 新增訂閱`;
      body.innerHTML = '<div class="text-ink-400 text-sm text-center py-4">載入中...</div>';
      footer.textContent = '';
      modal.classList.remove('hidden');

      closeBtn.onclick = () => modal.classList.add('hidden');
      modal.onclick = (e) => { if (e.target === modal) modal.classList.add('hidden'); };

      if (newCount === 0) {
        body.innerHTML = '<div class="text-ink-400 text-sm text-center py-4">當日無新增訂閱。</div>';
        footer.textContent = '共 0 人';
        return;
      }

      const admin = (window as any).__admin;
      const key = admin?.getKey();
      if (!key) return;

      try {
        const res = await fetch(`${admin.API_BASE}/api/kit/subscribers-by-date?key=${encodeURIComponent(key)}&date=${date}&form_id=${KIT_FORM_ID}`);
        const data = await res.json();

        if (data.success) {
          const subs = data.data.subscribers;
          body.innerHTML = subs.map((s: any) => {
            const time = new Date(s.created_at).toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit' });
            return `
              <div class="flex items-center justify-between py-2 border-b border-cream-200 last:border-0">
                <span class="text-ink-900">${escapeHtml(s.email)}</span>
                <span class="text-ink-400 text-xs">${time}</span>
              </div>
            `;
          }).join('');
          footer.textContent = `共 ${subs.length} 人`;
        } else {
          body.innerHTML = '<div class="text-red-600 text-sm text-center py-4">載入失敗。</div>';
        }
      } catch {
        body.innerHTML = '<div class="text-red-600 text-sm text-center py-4">載入失敗。</div>';
      }
    }

    function loadData() {
      const admin = (window as any).__admin;
      if (!admin) return;

      const key = admin.getKey();
      if (!key) return;

      // Load stats and trend in parallel
      // First load stats to get newsletter tag ID, then load trend filtered by tag
      fetch(`${admin.API_BASE}/api/kit/stats?key=${encodeURIComponent(key)}`)
        .then(r => r.json())
        .then(statsData => {
          if (statsData.success) renderStats(statsData);
          return fetch(`${admin.API_BASE}/api/kit/trend?key=${encodeURIComponent(key)}&days=30&form_id=${KIT_FORM_ID}`).then(r => r.json());
        })
        .then(trendData => {
          if (trendData.success) renderTrend(trendData);
        })
        .catch(() => {
          const loadingEl = document.getElementById('loading-state')!;
          loadingEl.textContent = '載入失敗，請重新整理頁面。';
        });
    }

    const observer = new MutationObserver(() => {
      const guard = document.getElementById('admin-auth-guard');
      if (guard && !guard.classList.contains('hidden')) {
        loadData();
        observer.disconnect();
      }
    });
    observer.observe(document.getElementById('admin-auth-guard')!, { attributes: true });
  </script>
</AdminLayout>
