---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { label: '總覽', href: '/admin/' },
  { label: '問卷回覆', href: '/admin/survey/' },
  { label: '電子報', href: '/admin/newsletter/' },
];
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap" rel="stylesheet" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400;6..72,600&family=Noto+Sans+TC:wght@400;500;600&family=Noto+Serif+TC:wght@400;600&display=swap"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-cream-100 text-ink-900 font-sans antialiased">

    <!-- Auth guard: show dashboard -->
    <div id="admin-auth-guard" class="hidden flex-1 flex flex-col">
      <Header hideLanguageSwitcher={true} />

      <!-- Admin nav bar -->
      <div class="bg-white border-b border-cream-300">
        <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-11">
          <div class="flex items-center gap-1">
            <span class="text-xs font-semibold text-ink-400 uppercase tracking-wider mr-3">Admin</span>
            {navItems.map(item => {
              const isActive = currentPath === item.href || currentPath === item.href.slice(0, -1);
              return (
                <a
                  href={item.href}
                  class:list={[
                    'px-3 py-1.5 rounded-md text-sm font-medium transition-colors',
                    isActive
                      ? 'bg-cream-200 text-ink-900'
                      : 'text-ink-500 hover:bg-cream-100 hover:text-ink-700',
                  ]}
                >
                  {item.label}
                </a>
              );
            })}
          </div>
          <button
            id="admin-logout-btn"
            class="text-xs text-ink-400 hover:text-ink-700 transition-colors"
          >
            登出
          </button>
        </div>
      </div>

      <!-- Main content -->
      <main class="flex-1 max-w-6xl mx-auto w-full px-6 py-8">
        <slot />
      </main>

      <Footer />
    </div>

    <!-- Login screen (shown when no auth) -->
    <div id="admin-login-screen" class="flex-1">
      <Header hideLanguageSwitcher={true} />
      <div class="min-h-[calc(100vh-200px)] flex items-center justify-center">
        <div class="w-full max-w-sm px-6">
          <h1 class="text-2xl font-semibold text-ink-900 mb-6 text-center">Admin 登入</h1>
          <form id="admin-login-form" class="bg-white border border-cream-300 rounded-xl p-6 shadow-sm" action="https://yu-wenhao.com/admin/" method="POST">
            <input type="hidden" name="username" autocomplete="username" value="admin" />
            <label for="admin-key-input" class="block text-sm font-medium text-ink-700 mb-2">Admin Key</label>
            <input
              type="password"
              id="admin-key-input"
              name="password"
              autocomplete="current-password"
              placeholder="輸入 admin key"
              class="w-full px-4 py-3 border border-cream-300 rounded-lg text-ink-900 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-colors mb-3"
            />
            <button
              type="submit"
              id="admin-login-btn"
              class="w-full px-4 py-3 bg-ink-900 text-white font-medium rounded-lg hover:bg-ink-800 transition-colors"
            >
              登入
            </button>
            <p id="admin-login-error" class="text-red-600 text-sm mt-2 hidden">驗證失敗，請確認 key 是否正確。</p>
          </form>
        </div>
      </div>
      <Footer />
    </div>

    <script>
      const API_BASE = 'https://yu-wenhao-api.calmisland-ea7fe91e.japaneast.azurecontainerapps.io';
      const AUTH_STORAGE_KEY = 'admin_key';

      // Prefetch warmup: wake up container while user types key
      fetch(`${API_BASE}/health`).catch(() => {});

      const authGuard = document.getElementById('admin-auth-guard')!;
      const loginScreen = document.getElementById('admin-login-screen')!;
      const loginForm = document.getElementById('admin-login-form') as HTMLFormElement;
      const loginBtn = document.getElementById('admin-login-btn')!;
      const loginInput = document.getElementById('admin-key-input') as HTMLInputElement;
      const loginError = document.getElementById('admin-login-error')!;
      const logoutBtn = document.getElementById('admin-logout-btn')!;

      async function verifyKey(key: string): Promise<boolean> {
        try {
          const res = await fetch(`${API_BASE}/api/survey/responses/meeting-tool?key=${encodeURIComponent(key)}`);
          return res.ok;
        } catch {
          return false;
        }
      }

      function showDashboard() {
        loginScreen.classList.add('hidden');
        authGuard.classList.remove('hidden');
      }

      function showLogin() {
        authGuard.classList.add('hidden');
        loginScreen.classList.remove('hidden');
      }

      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const key = loginInput.value.trim();
        if (!key) return;

        loginBtn.textContent = '驗證中...';
        loginError.classList.add('hidden');

        const valid = await verifyKey(key);
        if (valid) {
          sessionStorage.setItem(AUTH_STORAGE_KEY, key);
          showDashboard();
        } else {
          loginError.classList.remove('hidden');
        }
        loginBtn.textContent = '登入';
      });

      logoutBtn.addEventListener('click', () => {
        sessionStorage.removeItem(AUTH_STORAGE_KEY);
        window.location.href = '/zh-TW/';
      });

      // Auto-login check
      const savedKey = sessionStorage.getItem(AUTH_STORAGE_KEY);
      if (savedKey) {
        verifyKey(savedKey).then(valid => {
          if (valid) {
            showDashboard();
          } else {
            sessionStorage.removeItem(AUTH_STORAGE_KEY);
            showLogin();
          }
        });
      } else {
        showLogin();
      }

      // Expose API_BASE and key getter for child pages
      (window as any).__admin = {
        getKey: () => sessionStorage.getItem(AUTH_STORAGE_KEY),
        API_BASE,
      };
    </script>
  </body>
</html>
